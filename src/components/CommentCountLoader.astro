---
/**
 * Fetches comment counts for all [data-comment-slug] elements on the page
 * and injects a badge showing the count (only for non-zero counts).
 *
 * Usage: Add `data-comment-slug="the-slug"` and `data-comment-type="posts"`
 * to any element, then include this component once on the page.
 */
---

<script>
  const API_BASE = 'https://api.jiun.dev';
  const GITHUB_REPO = 'jiunbae/jiunbae.github.io';

  async function fetchLegacyCounts(slugs: string[]): Promise<Record<string, number>> {
    const counts: Record<string, number> = {};
    try {
      const queries = slugs.map((slug) => `"posts/${slug}/"`).join('+');
      const res = await fetch(
        `https://api.github.com/search/issues?q=${encodeURIComponent(`repo:${GITHUB_REPO} ${queries} in:title is:issue`)}`,
      );
      if (!res.ok) return counts;
      const data = await res.json();
      for (const issue of data.items || []) {
        const match = issue.title.match(/^posts\/(.+)\/$/);
        if (match && issue.comments > 0) {
          counts[match[1]] = issue.comments;
        }
      }
    } catch {
      // silently fail
    }
    return counts;
  }

  async function loadCommentCounts() {
    const elements = document.querySelectorAll<HTMLElement>('[data-comment-slug]');
    if (elements.length === 0) return;

    // Group by postType
    const byType = new Map<string, { slug: string; el: HTMLElement }[]>();
    elements.forEach((el) => {
      const slug = el.dataset.commentSlug!;
      const type = el.dataset.commentType || 'posts';
      if (!byType.has(type)) byType.set(type, []);
      byType.get(type)!.push({ slug, el });
    });

    for (const [postType, items] of byType) {
      const slugs = items.map((i) => i.slug);
      try {
        const [apiRes, legacyCounts] = await Promise.all([
          fetch(
            `${API_BASE}/comments/counts?slugs=${encodeURIComponent(slugs.join(','))}&postType=${postType}`,
          ).then((r) => (r.ok ? r.json() : { counts: {} })).catch(() => ({ counts: {} })),
          postType === 'posts' ? fetchLegacyCounts(slugs) : Promise.resolve({} as Record<string, number>),
        ]);
        const apiCounts: Record<string, number> = apiRes.counts || {};

        for (const { slug, el } of items) {
          const count = (apiCounts[slug] || 0) + (legacyCounts[slug] || 0);
          if (count > 0) {
            const badge = document.createElement('span');
            badge.className = 'comment-count-badge';
            badge.textContent = `💬 ${count}`;
            el.appendChild(badge);
          }
        }
      } catch {
        // silently fail
      }
    }
  }

  loadCommentCounts();
</script>

<style is:global>
  .comment-count-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    color: var(--gray-4);
    font-weight: 500;
    white-space: nowrap;
    margin-left: 0.5rem;
  }
</style>
