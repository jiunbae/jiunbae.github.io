---
import BaseHead from './BaseHead.astro';
import SearchModal from '@/components/SearchModal';

interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  tags?: string[];
}

const { title, description, image, ogType, publishedTime, tags } = Astro.props;
const pathname = Astro.url.pathname;

const baseNavLinks = [
  { to: '/', label: 'Posts' },
  { to: '/notes/', label: 'Notes' },
  { to: '/reviews/', label: 'Reviews' },
  { to: '/projects/', label: 'Projects' },
];

const isActivePath = (target: string) => {
  if (target === '/') {
    return pathname === '/' || pathname.startsWith('/posts/');
  }
  if (target === '/projects/') {
    return pathname.startsWith('/projects') || pathname.startsWith('/playground') || pathname.startsWith('/tools') || pathname.startsWith('/services');
  }
  return pathname.startsWith(target);
};
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={title} description={description} image={image} ogType={ogType} publishedTime={publishedTime} tags={tags} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="header" id="site-header">
      <div class="wrapper">
        <a href="/" class="heading-link" aria-label="Home">
          <div class="heading-wrapper">
            <span class="logo-icon">
              <svg width="28" height="28" viewBox="96 128 320 256" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <g fill="currentColor">
                  <circle cx="138" cy="188" r="19"/>
                  <circle cx="138" cy="256" r="19"/>
                  <circle cx="138" cy="324" r="19"/>
                  <circle cx="195" cy="188" r="19"/>
                  <circle cx="195" cy="256" r="19"/>
                  <circle cx="195" cy="324" r="19"/>
                </g>
                <circle cx="324" cy="256" r="54" fill="none" stroke="currentColor" stroke-width="35"/>
              </svg>
            </span>
            <span class="heading">Jiun's</span>
          </div>
        </a>
        <div class="header-buttons">
          <!-- Desktop navigation -->
          <nav class="navigation desktop-only" aria-label="Main navigation">
            {baseNavLinks.map(link => (
              <a
                href={link.to}
                class:list={['link', { 'active-link': isActivePath(link.to) }]}
                aria-current={isActivePath(link.to) ? 'page' : undefined}
              >
                {link.label}
              </a>
            ))}
            <span class="nav-divider desktop-only" aria-hidden="true"></span>
            <a href="/about/" class:list={['icon-link desktop-only', { 'active-icon': pathname.startsWith('/about') }]} aria-label="About page">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 20a6 6 0 0 0-12 0"/>
                <circle cx="12" cy="10" r="4"/>
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </a>
            <a href="/status/" class:list={['icon-link desktop-only', { 'active-icon': pathname.startsWith('/status') }]} aria-label="Status">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
              </svg>
            </a>
            <a href="/rss.xml" class="icon-link desktop-only" aria-label="RSS feed">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 11a9 9 0 0 1 9 9"/>
                <path d="M4 4a16 16 0 0 1 16 16"/>
                <circle cx="5" cy="19" r="1"/>
              </svg>
            </a>
            <button class="icon-button desktop-only" id="search-toggle" aria-label="Search">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/>
              </svg>
            </button>
            <button class="icon-button desktop-only" id="theme-toggle-desktop" aria-label="Toggle theme">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 23 23" fill="currentColor" stroke="currentColor">
                <path d="M3.96326 16.1073L2.66133 15.7425L3.41265 16.8666C4.20961 18.059 5.26107 19.0598 6.49131 19.797C7.72155 20.5342 9.09997 20.9895 10.5273 21.1299C11.9546 21.2704 13.3953 21.0926 14.7457 20.6093C16.096 20.126 17.3224 19.3493 18.3365 18.3352C19.3506 17.321 20.1271 16.0945 20.6103 14.7441C21.0934 13.3938 21.2711 11.953 21.1305 10.5257C20.9899 9.09842 20.5346 7.72005 19.7973 6.48987C19.06 5.25969 18.059 4.20833 16.8665 3.41148L15.7424 2.66026L16.1073 3.96216C16.5792 5.64563 16.5944 7.42439 16.1512 9.11566C15.708 10.8069 14.8226 12.3497 13.5857 13.5854L13.5855 13.5857C12.3498 14.8224 10.8072 15.7077 9.11618 16.1509C7.42512 16.594 5.64658 16.579 3.96326 16.1073ZM11.5 22.5C5.42469 22.5 0.5 17.5753 0.5 11.5C0.5 5.42469 5.42469 0.5 11.5 0.5C17.5753 0.5 22.5 5.42469 22.5 11.5C22.5 17.5753 17.5753 22.5 11.5 22.5Z"/>
              </svg>
            </button>
          </nav>

          <!-- Mobile navigation -->
          <div class="mobile-only" id="mobile-nav">
            <span class="current-page" id="current-page-label">
              {(() => {
                if (pathname.startsWith('/notes')) return 'Notes';
                if (pathname.startsWith('/reviews')) return 'Reviews';
                if (pathname.startsWith('/projects')) return 'Projects';
                if (pathname.startsWith('/playground')) return 'Playground';
                if (pathname.startsWith('/tools')) return 'Tools';
                if (pathname.startsWith('/status')) return 'Status';
                if (pathname.startsWith('/about')) return 'About';
                return 'Posts';
              })()}
            </span>
            <button class="mobile-icon-btn" id="search-toggle-mobile" aria-label="Search">
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <path d="m21 21-4.35-4.35"/>
              </svg>
            </button>
            <button class="mobile-icon-btn" id="hamburger-btn" aria-label="Menu" aria-expanded="false" aria-controls="drawer">
              <svg aria-hidden="true" class="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
              <svg aria-hidden="true" class="close-icon" style="display:none" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"/>
                <line x1="6" y1="6" x2="18" y2="18"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
      <div class="progress-bar" id="progress-bar" aria-hidden="true"></div>
    </header>

    <!-- Mobile drawer overlay -->
    <div class="drawer-overlay" id="drawer-overlay"></div>
    <!-- Mobile drawer -->
    <nav class="drawer" id="drawer" role="dialog" aria-modal="true" aria-label="Mobile navigation" inert>
      <div class="drawer-content">
        <div class="drawer-links">
          {baseNavLinks.map(link => (
            <a
              href={link.to}
              class:list={['drawer-link', { 'drawer-active': isActivePath(link.to) }]}
              aria-current={isActivePath(link.to) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
        <hr class="drawer-divider" />
        <div class="drawer-actions">
          <a href="/about/" class="drawer-action">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20a6 6 0 0 0-12 0"/><circle cx="12" cy="10" r="4"/><circle cx="12" cy="12" r="10"/></svg>
            <span>About</span>
          </a>
          <a href="/status/" class="drawer-action">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            <span>Status</span>
          </a>
          <a href="/rss.xml" class="drawer-action">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
            <span>RSS Feed</span>
          </a>
          <button class="drawer-action" id="theme-toggle-drawer" aria-label="Toggle theme">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 23 23" fill="currentColor" stroke="currentColor"><path d="M3.96326 16.1073L2.66133 15.7425L3.41265 16.8666C4.20961 18.059 5.26107 19.0598 6.49131 19.797C7.72155 20.5342 9.09997 20.9895 10.5273 21.1299C11.9546 21.2704 13.3953 21.0926 14.7457 20.6093C16.096 20.126 17.3224 19.3493 18.3365 18.3352C19.3506 17.321 20.1271 16.0945 20.6103 14.7441C21.0934 13.3938 21.2711 11.953 21.1305 10.5257C20.9899 9.09842 20.5346 7.72005 19.7973 6.48987C19.06 5.25969 18.059 4.20833 16.8665 3.41148L15.7424 2.66026L16.1073 3.96216C16.5792 5.64563 16.5944 7.42439 16.1512 9.11566C15.708 10.8069 14.8226 12.3497 13.5857 13.5854L13.5855 13.5857C12.3498 14.8224 10.8072 15.7077 9.11618 16.1509C7.42512 16.594 5.64658 16.579 3.96326 16.1073ZM11.5 22.5C5.42469 22.5 0.5 17.5753 0.5 11.5C0.5 5.42469 5.42469 0.5 11.5 0.5C17.5753 0.5 22.5 5.42469 22.5 11.5C22.5 17.5753 17.5753 22.5 11.5 22.5Z"/></svg>
            <span>Theme</span>
          </button>
        </div>
      </div>
    </nav>

    <SearchModal client:idle />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="footer">
      <span class="copy-right">Copyright © {new Date().getFullYear()}. jiunbae. All rights reserved.</span>
    </footer>

    <!-- Scroll to top button -->
    <button class="scroll-to-top" id="scroll-to-top" aria-label="Scroll to top">
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m18 15-6-6-6 6"/>
      </svg>
    </button>

    <script>
      // Theme toggle helper
      function doToggleTheme() {
        const currentTheme = document.documentElement.dataset.theme;
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = newTheme;
        localStorage.setItem('theme', newTheme);
      }

      // Desktop theme toggle
      document.getElementById('theme-toggle-desktop')?.addEventListener('click', doToggleTheme);
      // Drawer theme toggle
      document.getElementById('theme-toggle-drawer')?.addEventListener('click', () => {
        doToggleTheme();
        closeDrawer();
      });

      // Header shrink effect
      const header = document.getElementById('site-header');
      const handleHeaderShrink = () => {
        if (!header) return;
        if (window.scrollY > 0) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      };
      // Progress bar
      const progressBar = document.getElementById('progress-bar');
      const updateProgressBar = () => {
        if (!progressBar) return;
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
        progressBar.style.width = `${scrollPercent}%`;
      };

      // Scroll to top button
      const scrollToTopBtn = document.getElementById('scroll-to-top');
      const toggleScrollBtn = () => {
        if (!scrollToTopBtn) return;
        if (window.scrollY > 300) {
          scrollToTopBtn.classList.add('visible');
        } else {
          scrollToTopBtn.classList.remove('visible');
        }
      };

      // Consolidated rAF-throttled scroll handler
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            handleHeaderShrink();
            updateProgressBar();
            toggleScrollBtn();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });

      // Run once on load
      handleHeaderShrink();
      updateProgressBar();
      toggleScrollBtn();

      scrollToTopBtn?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });

      // Mobile drawer
      const hamburgerBtn = document.getElementById('hamburger-btn');
      const drawer = document.getElementById('drawer');
      const drawerOverlay = document.getElementById('drawer-overlay');
      const menuIcon = hamburgerBtn?.querySelector('.menu-icon') as HTMLElement;
      const closeIcon = hamburgerBtn?.querySelector('.close-icon') as HTMLElement;

      // Focus trap이 잡힐 후보 — 보이는 + 비활성 아닌 + tabIndex >= 0
      function focusableInDrawer(): HTMLElement[] {
        if (!drawer) return [];
        const candidates = drawer.querySelectorAll<HTMLElement>('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])');
        return Array.from(candidates).filter(el => {
          if (el.hasAttribute('disabled')) return false;
          if (el.getAttribute('aria-hidden') === 'true') return false;
          const rect = el.getBoundingClientRect();
          if (rect.width === 0 && rect.height === 0) return false;
          const style = window.getComputedStyle(el);
          return style.visibility !== 'hidden' && style.display !== 'none';
        });
      }

      const mainEl = document.getElementById('main-content');
      function openDrawer() {
        if (!drawer) return;
        drawer.classList.add('open');
        drawer.removeAttribute('inert');
        drawerOverlay?.classList.add('open');
        if (menuIcon) menuIcon.style.display = 'none';
        if (closeIcon) closeIcon.style.display = 'block';
        hamburgerBtn?.setAttribute('aria-expanded', 'true');
        hamburgerBtn?.setAttribute('aria-label', 'Close menu');
        document.body.style.overflow = 'hidden';
        // Modal dialog: 배경 main을 inert로 — SR이 hidden 콘텐츠를 탐색하지 못하도록
        mainEl?.setAttribute('inert', '');
        // Focus first focusable link
        focusableInDrawer()[0]?.focus();
      }

      function closeDrawer() {
        if (!drawer) return;
        drawer.classList.remove('open');
        drawer.setAttribute('inert', '');
        drawerOverlay?.classList.remove('open');
        if (menuIcon) menuIcon.style.display = 'block';
        if (closeIcon) closeIcon.style.display = 'none';
        hamburgerBtn?.setAttribute('aria-expanded', 'false');
        hamburgerBtn?.setAttribute('aria-label', 'Menu');
        document.body.style.overflow = 'unset';
        mainEl?.removeAttribute('inert');
        // Return focus to hamburger button
        hamburgerBtn?.focus();
      }

      hamburgerBtn?.addEventListener('click', () => {
        const isOpen = drawer?.classList.contains('open');
        isOpen ? closeDrawer() : openDrawer();
      });

      drawerOverlay?.addEventListener('click', closeDrawer);

      drawer?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeDrawer);
      });

      // ESC to close drawer + focus trap
      document.addEventListener('keydown', (e) => {
        if (!drawer?.classList.contains('open')) return;
        if (e.key === 'Escape') {
          closeDrawer();
          return;
        }
        if (e.key === 'Tab') {
          const focusable = focusableInDrawer();
          if (focusable.length === 0) return;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last?.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first?.focus();
          }
        }
      });

      // Search toggle (desktop + mobile)
      document.getElementById('search-toggle')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-search'));
      });
      document.getElementById('search-toggle-mobile')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('toggle-search'));
      });
    </script>

    <!-- Mermaid support (only loaded when .mermaid elements exist) -->
    <script type="module">
      if (document.querySelectorAll('.mermaid').length > 0) {
        const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@10.9.1/dist/mermaid.esm.min.mjs');

        const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default';
        mermaid.initialize({
          startOnLoad: true,
          theme: theme,
          securityLevel: 'strict'
        });

        // Store original source for re-rendering
        document.querySelectorAll('.mermaid').forEach((el) => {
          el.setAttribute('data-mermaid-src', el.textContent || '');
        });

        // Re-render on theme change
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === 'data-theme') {
              const newTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default';
              mermaid.initialize({ theme: newTheme, securityLevel: 'strict' });
              document.querySelectorAll('.mermaid').forEach((el) => {
                const code = el.getAttribute('data-mermaid-src');
                if (code) {
                  el.textContent = code;
                  el.removeAttribute('data-processed');
                }
              });
              mermaid.run();
            }
          });
        });
        observer.observe(document.documentElement, { attributes: true });
      }
    </script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-8JQSR962RQ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-8JQSR962RQ');
    </script>
  </body>
</html>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    padding: var(--space-2) var(--space-3);
    background: var(--accent-default);
    color: var(--text-on-accent);
    font-family: var(--font-mono);
    @include caption;
    font-weight: 600;
    border-radius: 0 0 var(--radius-md) 0;
    z-index: var(--z-toast);

    &:focus {
      top: 0;
      outline: 2px solid var(--border-focus);
      outline-offset: 2px;
    }
  }

  @media (forced-colors: active) {
    .skip-link {
      forced-color-adjust: none;
      background: Canvas;
      color: CanvasText;
      border: 2px solid CanvasText;
    }
    .skip-link:focus { outline: 2px solid CanvasText; outline-offset: 2px; }
  }

  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: var(--header-bg);
    box-shadow: var(--shadow-sm);

    &.scrolled {
      .heading-wrapper {
        .logo-icon svg {
          width: 28px;
          height: 28px;
        }
        .heading {
          display: none;
          @include heading-2;
        }
      }

      .wrapper {
        height: 52px;
        padding: var(--space-2) var(--space-5);
        transition: height var(--duration-slow) var(--easing-standard);
      }

      .icon {
        width: 20px;
        height: 20px;
      }

      .link {
        @include caption;
      }
    }
  }

  .progress-bar {
    width: 0;
    height: 2px;
    background-color: var(--primary-c1);
    transition: width var(--duration-fast) var(--easing-decelerate);
  }

  .wrapper {
    display: flex;
    justify-content: space-between;
    padding: var(--space-5);

    @include tabletAndUp {
      padding: var(--space-5) var(--space-16);
    }
  }

  .heading-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .heading-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0;

    .logo-icon {
      display: flex;
      align-items: center;
      justify-content: center;

      svg {
        width: 32px;
        height: 32px;
        transition: width var(--duration-slow) var(--easing-standard), height var(--duration-slow) var(--easing-standard);
      }
    }

    .heading {
      display: none;
      font-weight: 800;
      @include heading-1;
      line-height: 1.5rem;
      color: var(--icon-color);

      @include tabletAndUp {
        display: inline-block;
      }
    }
  }

  .header-buttons {
    display: flex;
    align-items: center;
    gap: var(--space-3);

    @include tabletAndUp {
      gap: var(--space-5);
    }
  }

  .desktop-only {
    display: none;

    @include tabletAndUp {
      display: flex;
    }
  }

  .mobile-only {
    display: flex;
    align-items: center;
    gap: var(--space-2);

    @include tabletAndUp {
      display: none;
    }
  }

  .navigation {
    align-items: center;
    gap: var(--space-4);
  }

  .link {
    text-decoration: none;
    color: var(--icon-color);
    font-weight: 600;
    @include body;
    opacity: 0.7;
    transition: opacity var(--duration-base) var(--easing-standard);

    &:hover {
      opacity: 1;
    }

    &.active-link {
      color: var(--primary-c1);
      opacity: 1;
    }
  }

  /* 1차 nav 텍스트 링크와 유틸리티 아이콘 cluster를 시각적으로 구분 (Gestalt common region) */
  .nav-divider {
    display: inline-block;
    width: 1px;
    height: 18px;
    background: var(--border-default);
    margin: 0 var(--space-2);
    align-self: center;
  }

  .icon-link, .icon-button {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    opacity: 0.7;
    color: var(--icon-color);
    background: none;
    border: none;
    cursor: pointer;
    transition: opacity var(--duration-base) var(--easing-standard);

