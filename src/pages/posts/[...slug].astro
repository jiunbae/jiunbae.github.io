---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import CommentSection from '@/components/CommentSection';
import { fmtDateKr } from '@/utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.published !== false);
  return posts.map((post) => {
    const permalink = post.data.permalink || '';
    const slug = permalink.startsWith('/') ? permalink.slice(1) : permalink;
    return {
      params: { slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter(h => h.depth <= 3);
const rawHeroImage = post.data.heroImage && post.data.heroImage.trim() ? post.data.heroImage : undefined;

// Resolve heroImage: absolute paths/URLs used directly, relative paths resolved via glob
const contentImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/posts/**/*.{png,jpg,jpeg,gif,webp}',
  { eager: true }
);

let heroImage: string | undefined;
if (rawHeroImage) {
  if (rawHeroImage.startsWith('/') || rawHeroImage.startsWith('http')) {
    heroImage = rawHeroImage;
  } else if (rawHeroImage.startsWith('./')) {
    const postDir = post.id.includes('/') ? post.id.split('/')[0] : post.id;
    const imageName = rawHeroImage.slice(2);
    const key = `/src/content/posts/${postDir}/${imageName}`;
    const mod = contentImages[key];
    if (mod) {
      heroImage = mod.default.src;
    }
  }
}

let postSlug = post.data.permalink || post.slug;
if (postSlug.startsWith('/')) postSlug = postSlug.slice(1);
const ogImage = heroImage || `/og/posts/${postSlug}.png`;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  ogType="article"
  publishedTime={post.data.date.toISOString()}
  tags={post.data.tags}
>
  <article class="article">
    {heroImage && (
      <div class="hero-image">
        <img src={heroImage} alt={post.data.heroImageAlt || post.data.title} />
      </div>
    )}

    <header class="article-header">
      <h1 class="article-title">{post.data.title}</h1>

      {post.data.tags.length > 0 && (
        <div class="article-tags">
          {post.data.tags.map(tag => (
            <a href={`/posts/?tag=${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )}

      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>
          {fmtDateKr(post.data.date)}
        </time>
      </div>

      {post.data.description && (
        <p class="article-description">{post.data.description}</p>
      )}
    </header>

    {toc.length > 2 && (
      <nav class="toc" aria-label="Table of Contents">
        <details>
          <summary>목차</summary>
          <ul class="toc-list">
            {toc.map(heading => (
              <li class={`toc-item depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </details>
      </nav>
    )}

    <div class="article-content prose">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/" class="back-link">← 목록으로 돌아가기</a>
    </footer>

    <!-- Comments -->
    <section class="comments">
      <CommentSection client:load postSlug={postSlug} postType="posts" />
    </section>
  </article>
</Layout>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .article {
    max-width: 780px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .hero-image {
    margin: 0 -1.5rem 2rem;

    img {
      width: 100%;
      height: auto;
      max-height: 400px;
      object-fit: cover;
    }
  }

  .article-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-default);
  }

  .article-title {
    @include display-2;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin: 0 0 1rem;
    word-break: keep-all;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    padding: 0.25rem 0.75rem;
    background: var(--surface-raised);
    border-radius: 0.25rem;
    @include caption;
    color: var(--accent-default);
    text-decoration: none;
    transition: all 0.2s;

    &:hover {
      background: var(--accent-default);
      color: white;
    }
  }

  .article-meta {
    color: var(--text-muted);
    @include body-sm;
    margin-bottom: 1rem;
  }

  .article-description {
    @include body-lg;
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }

  .toc {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--surface-raised);
    border-radius: 0.5rem;
    border-left: 3px solid var(--accent-default);

    summary {
      font-weight: 600;
      cursor: pointer;
      color: var(--text-secondary);
      @include body-sm;
    }
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
  }

  .toc-item {
    margin: 0.375rem 0;

    a {
      color: var(--text-secondary);
      text-decoration: none;
      @include body-sm;

      &:hover {
        color: var(--accent-default);
      }
    }

    &.depth-2 {
      padding-left: 1rem;
    }

    &.depth-3 {
      padding-left: 2rem;
      @include caption;
    }
  }

  .article-content {
    max-width: var(--measure);
    margin-inline: auto;
    @include body-lg;
    line-height: 1.85;
    color: var(--text-secondary);
    word-break: keep-all;

    :global(h2) {
      @include heading-1;
      font-weight: 700;
      margin: 3rem 0 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border-default);
      color: var(--text-primary);
    }

    :global(h3) {
      @include heading-2;
      font-weight: 600;
      margin: 2rem 0 0.75rem;
      color: var(--text-primary);
    }

    :global(h4) {
      @include heading-3;
      font-weight: 600;
      margin: 1.5rem 0 0.5rem;
      color: var(--text-primary);
    }

    :global(p) {
      margin: 1.25rem 0;
    }

    :global(ul), :global(ol) {
      margin: 1rem 0;
      padding-left: 1.5rem;
    }

    :global(li) {
      margin: 0.5rem 0;
    }

    :global(blockquote) {
      margin: 1.5rem 0;
      padding: 1rem 1.5rem;
      border-left: 4px solid var(--accent-default);
      background: var(--surface-raised);
      color: var(--text-secondary);
      border-radius: 0 0.5rem 0.5rem 0;

      :global(p) {
        margin: 0;
      }
    }

    :global(img) {
      max-width: 100%;
      height: auto;
      border-radius: 0.5rem;
      margin: 1.5rem auto;
      display: block;
    }

    :global(a) {
      color: var(--accent-default);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    :global(code:not(pre code)) {
      padding: 0.15rem 0.4rem;
      background: var(--code-inline-bg, rgba(0, 0, 0, 0.05));
      border-radius: 0.25rem;
      font-size: 0.875em;
      font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Mono', monospace;
      color: var(--code-inline-color, var(--state-error));
    }

    :global(.expressive-code) {
      margin: 1.5rem 0;
    }

    :global(pre) {
      margin: 1.5rem 0;
      border-radius: 0.5rem;
      overflow-x: auto;
    }

    :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin: 1.5rem 0;
      @include body-sm;

      :global(th), :global(td) {
        padding: 0.75rem;
        border: 1px solid var(--border-default);
        text-align: left;
      }

      :global(th) {
        background: var(--surface-raised);
        font-weight: 600;
      }
    }

    :global(hr) {
      margin: 2rem 0;
      border: none;
      border-top: 1px solid var(--border-default);
    }

    :global(strong) {
      font-weight: 600;
      color: var(--text-primary);
    }
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-default);
  }

  .back-link {
    color: var(--accent-default);
    font-weight: 500;
    text-decoration: none;

    &:hover {
      text-decoration: underline;
    }
  }

  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-default);
  }

  @media (max-width: 768px) {
    .article-title {
      @include heading-1;
    }

    .article-content {
      @include body;

      :global(h2) {
        @include heading-2;
      }

      :global(h3) {
        @include heading-3;
      }
    }

    .hero-image {
      margin: 0 -1.5rem 1.5rem;
    }
  }
</style>
