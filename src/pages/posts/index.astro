---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import CommentCountLoader from '@/components/CommentCountLoader.astro';
import Chip from '@/components/Chip.astro';
import { fmtDate } from '@/utils/date';

const allPosts = await getCollection('posts', ({ data }) => data.published !== false);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique tags with counts
const tagCounts = sortedPosts.reduce((acc, post) => {
  post.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const totalCount = sortedPosts.length;
---

<Layout
  title="Posts | Jiunbae"
  description="기술 블로그 포스트 목록"
>
  <div class="main">
    <section class="wrapper">
      <h1 class="sr-only">Posts</h1>
      <div class="tag-list" id="tags-container" role="group" aria-label="Filter by tag">
        <Chip as="button" type="button" class="tag-button active" pressed={true} data-tag="all">all ({totalCount})</Chip>
        {tags.map(([tag, count]) => (
          <Chip as="button" type="button" class="tag-button" pressed={false} data-tag={tag}>{tag} ({count})</Chip>
        ))}
      </div>

      <ul class="post-list" id="posts-list">
        {sortedPosts.map((post) => (
          <li class="post-item" data-tags={JSON.stringify(post.data.tags)}>
            <article class="post">
              <div class="post-content">
                <div class="post-header" data-comment-slug={(post.data.permalink || `/${post.id}`).replace(/^\//, '')} data-comment-type="posts">
                  <time class="post-date" datetime={post.data.date.toISOString()}>
                    {fmtDate(post.data.date)}
                  </time>
                </div>
                <h2 class="post-title">
                  <a href={`/posts${post.data.permalink || `/${post.id}`}`} class="post-link">{post.data.title}</a>
                </h2>
                {post.data.description && (
                  <p class="post-description">{post.data.description}</p>
                )}
                {post.data.tags.length > 0 && (
                  <div class="post-tags">
                    {post.data.tags.map(tag => (
                      <Chip>{tag}</Chip>
                    ))}
                  </div>
                )}
              </div>
              {post.data.heroImage && !post.data.heroImage.startsWith('./') && (
                <div class="post-thumbnail">
                  <img src={post.data.heroImage} alt="" loading="lazy" />
                </div>
              )}
            </article>
          </li>
        ))}
      </ul>
      <p class="empty-filter-message" id="empty-filter-msg" role="status" aria-live="polite" style="display:none">선택한 태그에 해당하는 포스트가 없습니다.</p>
    </section>
  </div>
  <CommentCountLoader />
</Layout>

<script>
  const tagsContainer = document.getElementById('tags-container');
  const postsList = document.getElementById('posts-list');

  // Pre-parse tags data for filtering
  const postItems = postsList?.querySelectorAll('.post-item');
  const tagData = new Map();
  postItems?.forEach(item => {
    tagData.set(item, JSON.parse((item as HTMLElement).dataset.tags || '[]'));
  });

  tagsContainer?.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('.tag-button') as HTMLElement;
    if (!target) return;
    const selectedTag = target.dataset.tag;

    // Update active tag: aria-pressed + .chip-active visual (matches Chip primitive contract)
    tagsContainer.querySelectorAll('.tag-button').forEach(btn => {
      btn.classList.remove('active');
      btn.classList.remove('chip-active');
      btn.classList.add('chip-default');
      btn.setAttribute('aria-pressed', 'false');
    });
    target.classList.add('active');
    target.classList.remove('chip-default');
    target.classList.add('chip-active');
    target.setAttribute('aria-pressed', 'true');

    // Filter posts
    let visibleCount = 0;
    postItems?.forEach((item) => {
      const postTags = tagData.get(item);
      if (selectedTag === 'all' || postTags.includes(selectedTag)) {
        (item as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });

    const emptyMsg = document.getElementById('empty-filter-msg');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
  });

  // Handle URL tag parameter
  const urlParams = new URLSearchParams(window.location.search);
  const tagParam = urlParams.get('tag');
  if (tagParam) {
    const tagButton = Array.from(
      tagsContainer?.querySelectorAll('.tag-button') ?? []
    ).find(btn => (btn as HTMLElement).dataset.tag === tagParam) as HTMLElement;
    tagButton?.click();
  }
</script>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .main {
    max-width: var(--container-doc);
    margin: 0 auto;
    padding: var(--space-6);
  }

  .wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* .tag-button 로컬 스타일 제거 — <Chip as="button" pressed>로 통일됨. */

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .post-item {
    border-bottom: 1px solid var(--border-default);
    padding: var(--space-4) var(--space-4);
    margin: 0 calc(var(--space-4) * -1);
    border-radius: var(--radius-md);
    position: relative; /* stretched-link */
    transition: background-color var(--duration-base) var(--easing-standard);

    &:last-child {
      border-bottom: none;
    }

    &:hover,
    &:has(.post-link:focus-visible) {
      background-color: var(--surface-hover);
    }

    @media (prefers-reduced-motion: reduce) {
      transition: none;
    }
  }

  /* Stretched link 패턴 — heading-in-link 회피하면서 카드 전체 클릭 영역 유지 */
  .post-link {
    text-decoration: none;
    color: inherit;

    &::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: var(--radius-md);
    }

    &:hover { color: var(--text-link); }

    &:focus-visible::after {
      outline: 2px solid var(--border-focus);
      outline-offset: 2px;
    }
  }

  .post {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
  }

  .post-content {
    flex: 1;
    min-width: 0;
  }

  .post-header {
    display: flex;
    align-items: center;
    margin-bottom: var(--space-2);
  }

  .post-date {
    @include caption;
    color: var(--text-muted);
  }

  .post-title {
    @include heading-3;
    color: var(--text-primary);
    margin: 0 0 var(--space-2);
  }

  .post-description {
    @include body-sm;
    color: var(--text-secondary);
    margin: 0 0 var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    position: relative; /* tag chips remain above stretched ::after */
    z-index: 2;
  }

  /* .tag 로컬 클래스 제거 — <Chip>으로 통일됨 */

  .post-thumbnail {
    flex-shrink: 0;
    width: 140px;
    height: 90px;
    border-radius: var(--radius-md);
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .empty-filter-message {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 1rem;
    @include body-sm;
  }

  @include belowTablet {
    .post {
      flex-direction: column-reverse;
      gap: var(--space-4);
    }

    .post-thumbnail {
      width: 100%;
      height: 160px;
    }

    .post-title {
      @include body;
    }
  }
</style>
