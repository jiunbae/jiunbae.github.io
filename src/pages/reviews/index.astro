---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { fmtDate } from '@/utils/date';
import Chip from '@/components/Chip.astro';

const allReviews = await getCollection('reviews', ({ data }) => data.published !== false);
const sortedReviews = allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getReviewHref = (permalink: string | undefined, slug: string) => {
  if (!permalink || !permalink.trim()) {
    return `/reviews/${slug}`;
  }

  let normalizedPermalink = permalink.trim();
  if (normalizedPermalink.startsWith('/reviews/')) {
    normalizedPermalink = normalizedPermalink.slice('/reviews'.length);
  } else if (!normalizedPermalink.startsWith('/')) {
    normalizedPermalink = `/${normalizedPermalink}`;
  }

  return `/reviews${normalizedPermalink}`;
};

// Resolve relative hero images (same pattern as [...slug].astro)
const contentImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/reviews/**/*.{png,jpg,jpeg,gif,webp,avif}',
  { eager: true }
);

const resolveHeroImage = (review: typeof sortedReviews[number]): string | undefined => {
  const raw = review.data.heroImage?.trim();
  if (!raw) return undefined;

  if (raw.startsWith('/') || raw.startsWith('http')) {
    return raw;
  }

  if (raw.startsWith('./')) {
    const reviewDir = review.id.includes('/') ? review.id.split('/')[0] : review.id;
    const imageName = raw.slice(2);
    const key = `/src/content/reviews/${reviewDir}/${imageName}`;
    const mod = contentImages[key];
    if (mod) return mod.default.src;
  }

  return undefined;
};

// Tag counts
const tagCounts = sortedReviews.reduce((acc, review) => {
  review.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const totalCount = sortedReviews.length;

// Rating display: ★ 3.5 / 5
const formatRating = (rating: number) => `★ ${rating.toFixed(1)}`;
---

<Layout
  title="Reviews"
  description="책, 영화, 콘텐츠 리뷰"
>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Reviews</h1>
      <p class="review-count">{totalCount} reviews</p>
    </header>

    <div class="tag-list" id="tags-container" role="group" aria-label="태그로 필터링">
      <Chip as="button" type="button" class="tag-button active" pressed={true} data-tag="all">all ({totalCount})</Chip>
      {tags.map(([tag, count]) => (
        <Chip as="button" type="button" class="tag-button" pressed={false} data-tag={tag}>{tag} ({count})</Chip>
      ))}
    </div>

    {sortedReviews.length === 0 ? (
      <p class="empty-message">아직 작성된 리뷰가 없습니다.</p>
    ) : (
      <section class="reviews-section">
        <ul class="reviews-grid" id="reviews-list">
          {sortedReviews.map((review) => {
            const heroImage = resolveHeroImage(review);
            const slug = review.data.permalink
              ? review.data.permalink.trim().replace(/^\/reviews\//, '/').replace(/^\//, '')
              : review.id;
            const ogFallback = `/og/reviews/${slug}.png`;
            const coverSrc = heroImage || ogFallback;
            return (
              <li class="review-item" data-tags={JSON.stringify(review.data.tags)}>
                <article class="review-card">
                  <div class="card-image">
                    <img
                      src={coverSrc}
                      alt=""
                      loading="lazy"
                    />
                  </div>
                  <div class="card-body">
                    <h2 class="card-title">
                      <a href={getReviewHref(review.data.permalink, review.id)} class="review-link">{review.data.title}</a>
                    </h2>
                    {typeof review.data.rating === 'number' && (
                      <p class="card-rating">
                        <span aria-hidden="true">{formatRating(review.data.rating)}</span>
                        <span class="sr-only">평점 {review.data.rating.toFixed(1)}점</span>
                      </p>
                    )}
                    {review.data.tags.length > 0 && (
                      <div class="card-tags">
                        {review.data.tags.map(tag => (
                          <Chip>{tag}</Chip>
                        ))}
                      </div>
                    )}
                  </div>
                </article>
              </li>
            );
          })}
        </ul>
        <p class="empty-filter-message" id="empty-filter-msg" role="status" aria-live="polite" style="display:none">선택한 태그에 해당하는 리뷰가 없습니다.</p>
      </section>
    )}
  </div>
</Layout>

<script>
  const tagsContainer = document.getElementById('tags-container');
  const reviewsList = document.getElementById('reviews-list');

  const reviewItems = reviewsList?.querySelectorAll('.review-item');
  const tagData = new Map<Element, string[]>();
  reviewItems?.forEach(item => {
    tagData.set(item, JSON.parse((item as HTMLElement).dataset.tags || '[]'));
  });

  tagsContainer?.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('.tag-button') as HTMLElement;
    if (!target) return;
    const selectedTag = target.dataset.tag;

    tagsContainer.querySelectorAll('.tag-button').forEach(btn => {
      btn.classList.remove('active');
      btn.classList.remove('chip-active');
      btn.classList.add('chip-default');
      btn.setAttribute('aria-pressed', 'false');
    });
    target.classList.add('active');
    target.classList.remove('chip-default');
    target.classList.add('chip-active');
    target.setAttribute('aria-pressed', 'true');

    let visibleCount = 0;
    reviewItems?.forEach((item) => {
      const itemTags = tagData.get(item);
      if (selectedTag === 'all' || itemTags?.includes(selectedTag!)) {
        (item as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });

    const emptyMsg = document.getElementById('empty-filter-msg');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
  });

  const urlParams = new URLSearchParams(window.location.search);
  const tagParam = urlParams.get('tag');
  if (tagParam) {
    const tagButton = Array.from(
      tagsContainer?.querySelectorAll('.tag-button') ?? []
    ).find(btn => (btn as HTMLElement).dataset.tag === tagParam) as HTMLElement;
    tagButton?.click();
  }
</script>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .container {
    max-width: var(--container-catalog);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-default);
  }

  .page-title {
    @include display-2;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .review-count {
    color: var(--text-muted);
    @include body-sm;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  /* .tag-button 로컬 스타일은 <Chip as="button" pressed>로 통일됨 */

  .empty-message,
  .empty-filter-message {
    @include body-sm;
    color: var(--text-muted);
    text-align: center;
    padding: var(--space-12) var(--space-4);
  }

  .reviews-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }

  .review-item {
    min-width: 0;
    position: relative; /* stretched-link */
  }

  .review-card {
    height: 100%;
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--duration-base) var(--easing-standard),
                box-shadow var(--duration-base) var(--easing-standard);

    &:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lg);
    }
  }

  /* Stretched link: 카드 전체 클릭 가능, 제목만 wrapping anchor */
  .review-link {
    text-decoration: none;
    color: inherit;

    &::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: var(--radius-md);
    }

    &:hover { color: var(--text-link); }
    &:focus-visible::after {
      outline: 2px solid var(--border-focus);
      outline-offset: 2px;
    }
  }

  .card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--surface-subtle);

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  .card-body {
    padding: var(--space-3);
  }

  .card-title {
    @include heading-3;
    margin: 0 0 var(--space-1);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    color: var(--text-primary);
  }

  .card-rating {
    @include caption;
    color: var(--accent-default);
    margin: 0 0 var(--space-1);
    letter-spacing: 1px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    position: relative;
    z-index: 2; /* chips remain above stretched ::after */
  }

  /* .tag-pill 로컬 클래스 제거 — <Chip>으로 통일 */

  @include belowDesktop {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @include belowTablet {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-3);
    }

    .card-title {
      @include caption;
    }

    .card-rating {
      @include caption;
    }
  }
</style>
