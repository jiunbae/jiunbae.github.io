---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { fmtDate } from '@/utils/date';

const allReviews = await getCollection('reviews', ({ data }) => data.published !== false);
const sortedReviews = allReviews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const getReviewHref = (permalink: string | undefined, slug: string) => {
  if (!permalink || !permalink.trim()) {
    return `/reviews/${slug}`;
  }

  let normalizedPermalink = permalink.trim();
  if (normalizedPermalink.startsWith('/reviews/')) {
    normalizedPermalink = normalizedPermalink.slice('/reviews'.length);
  } else if (!normalizedPermalink.startsWith('/')) {
    normalizedPermalink = `/${normalizedPermalink}`;
  }

  return `/reviews${normalizedPermalink}`;
};

// Resolve relative hero images (same pattern as [...slug].astro)
const contentImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/reviews/**/*.{png,jpg,jpeg,gif,webp,avif}',
  { eager: true }
);

const resolveHeroImage = (review: typeof sortedReviews[number]): string | undefined => {
  const raw = review.data.heroImage?.trim();
  if (!raw) return undefined;

  if (raw.startsWith('/') || raw.startsWith('http')) {
    return raw;
  }

  if (raw.startsWith('./')) {
    const reviewDir = review.id.includes('/') ? review.id.split('/')[0] : review.id;
    const imageName = raw.slice(2);
    const key = `/src/content/reviews/${reviewDir}/${imageName}`;
    const mod = contentImages[key];
    if (mod) return mod.default.src;
  }

  return undefined;
};

// Tag counts
const tagCounts = sortedReviews.reduce((acc, review) => {
  review.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const totalCount = sortedReviews.length;

// Rating display: ★ 3.5 / 5
const formatRating = (rating: number) => `★ ${rating.toFixed(1)}`;
---

<Layout
  title="Reviews"
  description="책, 영화, 콘텐츠 리뷰"
>
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Reviews</h1>
      <p class="review-count">{totalCount} reviews</p>
    </header>

    <div class="tag-list" id="tags-container" role="group" aria-label="태그로 필터링">
      <button class="tag-button active" data-tag="all" aria-pressed="true">
        all ({totalCount})
      </button>
      {tags.map(([tag, count]) => (
        <button class="tag-button" data-tag={tag} aria-pressed="false">
          {tag} ({count})
        </button>
      ))}
    </div>

    {sortedReviews.length === 0 ? (
      <p class="empty-message">아직 작성된 리뷰가 없습니다.</p>
    ) : (
      <section class="reviews-section">
        <ul class="reviews-grid" id="reviews-list">
          {sortedReviews.map((review) => {
            const heroImage = resolveHeroImage(review);
            const slug = review.data.permalink
              ? review.data.permalink.trim().replace(/^\/reviews\//, '/').replace(/^\//, '')
              : review.slug;
            const ogFallback = `/og/reviews/${slug}.png`;
            const coverSrc = heroImage || ogFallback;
            return (
              <li class="review-item" data-tags={JSON.stringify(review.data.tags)}>
                <a href={getReviewHref(review.data.permalink, review.slug)} class="review-link">
                  <article class="review-card">
                    <div class="card-image">
                      <img
                        src={coverSrc}
                        alt={review.data.heroImageAlt || review.data.title}
                        loading="lazy"
                      />
                    </div>
                    <div class="card-body">
                      <h2 class="card-title">{review.data.title}</h2>
                      {typeof review.data.rating === 'number' && (
                        <p class="card-rating" aria-label={`평점 ${review.data.rating.toFixed(1)}점`}>
                          {formatRating(review.data.rating)}
                        </p>
                      )}
                      {review.data.tags.length > 0 && (
                        <div class="card-tags">
                          {review.data.tags.map(tag => (
                            <span class="tag-pill">{tag}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  </article>
                </a>
              </li>
            );
          })}
        </ul>
        <p class="empty-filter-message" id="empty-filter-msg" style="display:none">선택한 태그에 해당하는 리뷰가 없습니다.</p>
      </section>
    )}
  </div>
</Layout>

<script>
  const tagsContainer = document.getElementById('tags-container');
  const reviewsList = document.getElementById('reviews-list');

  const reviewItems = reviewsList?.querySelectorAll('.review-item');
  const tagData = new Map<Element, string[]>();
  reviewItems?.forEach(item => {
    tagData.set(item, JSON.parse((item as HTMLElement).dataset.tags || '[]'));
  });

  tagsContainer?.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('.tag-button') as HTMLElement;
    if (!target) return;
    const selectedTag = target.dataset.tag;

    tagsContainer.querySelectorAll('.tag-button').forEach(btn => {
      btn.classList.remove('active');
      btn.setAttribute('aria-pressed', 'false');
    });
    target.classList.add('active');
    target.setAttribute('aria-pressed', 'true');

    let visibleCount = 0;
    reviewItems?.forEach((item) => {
      const itemTags = tagData.get(item);
      if (selectedTag === 'all' || itemTags?.includes(selectedTag!)) {
        (item as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });

    const emptyMsg = document.getElementById('empty-filter-msg');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
  });

  const urlParams = new URLSearchParams(window.location.search);
  const tagParam = urlParams.get('tag');
  if (tagParam) {
    const tagButton = Array.from(
      tagsContainer?.querySelectorAll('.tag-button') ?? []
    ).find(btn => (btn as HTMLElement).dataset.tag === tagParam) as HTMLElement;
    tagButton?.click();
  }
</script>

<style lang="scss">
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--gray-5);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--gray-1);
    margin: 0;
  }

  .review-count {
    color: var(--gray-4);
    font-size: 0.9375rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .tag-button {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid var(--gray-5);
    border-radius: 2rem;
    font-size: 0.875rem;
    color: var(--gray-3);
    cursor: pointer;
    transition: all 0.2s;

    &:hover {
      border-color: var(--primary-c1);
      color: var(--primary-c1);
    }

    &.active {
      background: var(--primary-c1);
      border-color: var(--primary-c1);
      color: white;
    }
  }

  .empty-message {
    color: var(--gray-4);
    text-align: center;
    padding: 3rem;
  }

  .empty-filter-message {
    text-align: center;
    color: var(--gray-4);
    padding: 3rem 1rem;
    font-size: 0.9375rem;
  }

  .reviews-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .review-item {
    min-width: 0;
  }

  .review-link {
    text-decoration: none;
    display: block;
    height: 100%;
  }

  .review-card {
    height: 100%;
    background: var(--article-background);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    }
  }

  .card-image {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: var(--gray-5);

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
  }

  .card-body {
    padding: 0.75rem;
  }

  .card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--gray-1);
    margin: 0 0 0.375rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-rating {
    font-size: 0.8125rem;
    color: var(--primary-c1);
    margin: 0 0 0.375rem;
    letter-spacing: 1px;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .tag-pill {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border: 1px solid var(--gray-4);
    border-radius: 1rem;
    color: var(--gray-3);
    background: transparent;
  }

  @media (max-width: 1024px) {
    .reviews-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 640px) {
    .reviews-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .card-title {
      font-size: 0.8125rem;
    }

    .card-rating {
      font-size: 0.75rem;
    }
  }
</style>
