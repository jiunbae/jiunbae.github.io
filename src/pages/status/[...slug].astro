---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Badge from '@/components/Badge.astro';

type IncidentSeverity = 'critical' | 'major' | 'minor' | 'maintenance';
type IncidentStatus = 'investigating' | 'identified' | 'monitoring' | 'resolved' | 'scheduled';
type BadgeTone = 'success' | 'warning' | 'error' | 'info' | 'neutral' | 'accent';

const severityTone: Record<IncidentSeverity, BadgeTone> = {
  critical: 'error',
  major: 'warning',
  minor: 'warning',
  maintenance: 'info',
};
const statusTone: Record<IncidentStatus, BadgeTone> = {
  investigating: 'warning',
  identified: 'warning',
  monitoring: 'info',
  resolved: 'success',
  scheduled: 'info',
};

export async function getStaticPaths() {
  const incidents = await getCollection('incidents', ({ data }) => data.published !== false);
  return incidents.map((incident) => ({
    params: { slug: incident.slug },
    props: { incident },
  }));
}

const { incident } = Astro.props;
const { Content } = await render(incident);

const severityLabels: Record<string, string> = {
  critical: 'Critical',
  major: 'Major',
  minor: 'Minor',
  maintenance: 'Maintenance',
};

function formatDateTime(d: Date) {
  return d.toLocaleString('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  });
}

function formatTime(d: Date) {
  return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
}

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Duration calculation
function getDuration(start: Date, end?: Date) {
  const ms = (end || new Date()).getTime() - start.getTime();
  const mins = Math.round(ms / 60000);
  if (mins < 60) return `${mins}m`;
  const hours = Math.floor(mins / 60);
  const remainMins = mins % 60;
  return remainMins > 0 ? `${hours}h ${remainMins}m` : `${hours}h`;
}

const timelineStatusColors: Record<string, string> = {
  investigating: 'var(--state-warning)',
  identified: 'var(--state-warning)',
  monitoring: 'var(--state-info)',
  resolved: 'var(--state-success)',
  scheduled: 'var(--state-info)',
};
---

<Layout title={`${incident.data.title} — Status`} description={`Incident: ${incident.data.title}`} image={`/og/status/${incident.slug}.png`}>
  <article class="incident-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/status/">Status</a>
      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
      <span>Incident</span>
    </nav>

    <header class="incident-header">
      <div class="header-top">
        <Badge tone={severityTone[incident.data.severity as IncidentSeverity]} weight="solid">
          {severityLabels[incident.data.severity]}
        </Badge>
        <Badge tone={statusTone[incident.data.status as IncidentStatus]}>
          {incident.data.status}
        </Badge>
      </div>
      <h1>{incident.data.title}</h1>
      <div class="header-meta">
        <span class="meta-item">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          {formatDate(incident.data.date)}
        </span>
        {incident.data.resolvedDate && (
          <span class="meta-item meta-duration">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Duration: {getDuration(incident.data.date, incident.data.resolvedDate)}
          </span>
        )}
      </div>
    </header>

    <div class="content-grid">
      <div class="main-content">
        {incident.data.timeline.length > 0 && (
          <section class="timeline-section">
            <h2>Timeline</h2>
            <div class="timeline">
              {incident.data.timeline.map((entry, i) => (
                <div class:list={['timeline-entry', { 'timeline-last': i === incident.data.timeline.length - 1 }]}>
                  <div class="timeline-marker">
                    <span
                      class="timeline-dot"
                      style={`background: ${timelineStatusColors[entry.status] || 'var(--primary-c1)'};
                              box-shadow: 0 0 0 4px ${timelineStatusColors[entry.status] || 'var(--primary-c1)'}20`}
                    ></span>
                    {i < incident.data.timeline.length - 1 && <span class="timeline-line"></span>}
                  </div>
                  <div class="timeline-content">
                    <div class="timeline-meta">
                      <span class="timeline-time">{formatTime(entry.time)}</span>
                      <span
                        class="timeline-status"
                        style={`color: ${timelineStatusColors[entry.status] || 'var(--primary-c1)'}`}
                      >
                        {entry.status}
                      </span>
                    </div>
                    <p class="timeline-message">{entry.message}</p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        <section class="incident-body">
          <Content />
        </section>
      </div>

      <aside class="sidebar">
        <div class="sidebar-card">
          <h3>Affected Services</h3>
          <div class="service-tags">
            {incident.data.affectedServices.map(s => (
              <span class="service-tag">
                <span class="tag-dot" aria-hidden="true"></span>
                {s}
              </span>
            ))}
          </div>
        </div>

        <div class="sidebar-card">
          <h3>Details</h3>
          <dl class="details-list">
            <dt>Severity</dt>
            <dd>
              <span class:list={['severity-badge', 'badge-sm', `severity-${incident.data.severity}`]}>
                {severityLabels[incident.data.severity]}
              </span>
            </dd>
            <dt>Status</dt>
            <dd class="detail-status">{incident.data.status}</dd>
            <dt>Reported</dt>
            <dd>{formatDateTime(incident.data.date)}</dd>
            {incident.data.resolvedDate && (
              <>
                <dt>Resolved</dt>
                <dd>{formatDateTime(incident.data.resolvedDate)}</dd>
              </>
            )}
          </dl>
        </div>
      </aside>
    </div>

    <footer class="incident-footer">
      <a href="/status/" class="back-link">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Back to Status
      </a>
    </footer>
  </article>
</Layout>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .incident-page {
    max-width: var(--container-doc);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  // Breadcrumb
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    @include caption;

    a {
      color: var(--primary-c1);
      text-decoration: none;
      font-weight: 500;

      &:hover {
        text-decoration: underline;
      }
    }

    svg {
      color: var(--border-default);
    }

    span {
      color: var(--text-muted);
    }
  }

  // Header
  .incident-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--border-subtle);

    h1 {
      @include display-2;
      font-weight: 700;
      color: var(--text-primary);
      margin: var(--space-3) 0;
      line-height: 1.3;
    }
  }

  .header-top {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .severity-badge {
    @include eyebrow;
    font-weight: 600;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-md);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge-sm {
    @include eyebrow;
    padding: var(--space-0_5) var(--space-2);
  }

  .severity-critical {
    background: color-mix(in srgb, var(--state-error) 15%, transparent);
    color: var(--state-error);
  }

  .severity-major {
    background: color-mix(in srgb, var(--state-warning) 15%, transparent);
    color: var(--state-warning);
  }

  .severity-minor {
    background: color-mix(in srgb, var(--state-warning) 12%, transparent);
    color: var(--state-warning);
  }

  .severity-maintenance {
    background: color-mix(in srgb, var(--state-info) 15%, transparent);
    color: var(--state-info);
  }

  .status-pill {
    @include eyebrow;
    font-weight: 600;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-lg);
    text-transform: capitalize;
  }

  .pill-resolved {
    background: color-mix(in srgb, var(--state-success) 12%, transparent);
    color: var(--state-success);
  }

  .pill-investigating, .pill-identified {
    background: color-mix(in srgb, var(--state-warning) 12%, transparent);
    color: var(--state-warning);
  }

  .pill-monitoring {
    background: color-mix(in srgb, var(--state-info) 12%, transparent);
    color: var(--state-info);
  }

  .pill-scheduled {
    background: color-mix(in srgb, var(--state-info) 12%, transparent);
    color: var(--state-info);
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: rem(6px);
    color: var(--text-muted);
    @include caption;

    svg { flex-shrink: 0; }
  }

  // Content grid
  .content-grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: var(--space-8);
    align-items: start;
  }

  .main-content {
    min-width: 0;
    overflow-x: hidden;
  }

  // Timeline
  .timeline-section {
    margin-bottom: var(--space-8);

    h2 {
      @include heading-3;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0 0 var(--space-5);
    }
  }

  .timeline-entry {
    display: flex;
    gap: var(--space-4);
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 20px;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .timeline-line {
    width: 2px;
    flex: 1;
    background: var(--border-subtle);
    margin: var(--space-1) 0;
  }

  .timeline-content {
    padding-bottom: var(--space-6);
    flex: 1;
    min-width: 0;
  }

  .timeline-last .timeline-content {
    padding-bottom: 0;
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: rem(6px);
  }

  .timeline-time {
    @include caption;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .timeline-status {
    @include eyebrow;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .timeline-message {
    margin: 0;
    @include body-sm;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  // Sidebar
  .sidebar-card {
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    margin-bottom: var(--space-4);

    h3 {
      @include caption;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      margin: 0 0 var(--space-3);
    }
  }

  .service-tags {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .service-tag {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    @include caption;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--primary-c1);
    flex-shrink: 0;
  }

  .details-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2) var(--space-3);
    margin: 0;

    dt {
      @include caption;
      color: var(--text-muted);
      font-weight: 500;
      white-space: nowrap;
    }

    dd {
      @include caption;
      color: var(--text-secondary);
      margin: 0;
      text-align: right;
      overflow-wrap: break-word;
      min-width: 0;
    }
  }

  .detail-status {
    text-transform: capitalize;
  }

  // Body content
  .incident-body {
    max-width: var(--measure);
    margin-inline: auto;
    line-height: 1.8;
    color: var(--text-secondary);
    word-break: keep-all;
    overflow-x: hidden;

    :global(h2) {
      @include heading-2;
      font-weight: 600;
      margin: var(--space-8) 0 var(--space-3);
      color: var(--text-primary);
    }

    :global(h3) {
      @include body;
      font-weight: 600;
      margin: var(--space-6) 0 var(--space-2);
      color: var(--text-primary);
    }

    :global(p) {
      margin: var(--space-3) 0;
      @include body-sm;
      word-break: break-word;
    }

    :global(ul), :global(ol) {
      padding-left: var(--space-6);
      margin: var(--space-3) 0;
    }

    :global(li) {
      margin: var(--space-1) 0;
      @include body-sm;
      word-break: break-word;
    }

    :global(table) {
      width: 100%;
      @include caption;
      border-collapse: collapse;
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    :global(th), :global(td) {
      padding: var(--space-2) var(--space-3);
      border: 1px solid var(--border-subtle);
      text-align: left;
    }

    :global(th) {
      font-weight: 600;
      color: var(--text-secondary);
      background: var(--surface-raised);
    }

    :global(pre) {
      overflow-x: auto;
      max-width: 100%;
    }

    :global(code) {
      word-break: break-all;
    }

    :global(.expressive-code),
    :global(.expressive-code figure),
    :global(.expressive-code pre) {
      max-width: 100%;
      overflow-x: auto;
    }

    :global(img) {
      max-width: 100%;
      height: auto;
    }
  }

  // Ensure sidebar doesn't overflow
  .sidebar {
    min-width: 0;
  }

  // Footer
  .incident-footer {
    margin-top: 2.5rem;
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: rem(6px);
    color: var(--primary-c1);
    font-weight: 500;
    @include body-sm;
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    transition: background var(--duration-base) var(--easing-standard);

    &:hover {
      background: color-mix(in srgb, var(--primary-c1) 8%, transparent);
    }
  }

  @include belowTablet {
    .incident-page {
      padding: var(--space-6) var(--space-4);
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      order: -1;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }

    .sidebar-card {
      margin-bottom: 0;
    }

    .incident-header h1 {
      @include heading-2;
      word-break: keep-all;
    }

    .header-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }

    .timeline-message {
      @include caption;
    }

    .incident-body {
      :global(h2) { @include heading-3; }
      :global(h3) { @include body; }
      :global(p), :global(li) { @include caption; }
      :global(th), :global(td) { padding: var(--space-1) var(--space-2); @include caption; }
    }
  }

  @include belowMobile {
    .incident-page {
      padding: var(--space-4) var(--space-3);
    }

    .sidebar {
      grid-template-columns: 1fr;
    }

    .incident-header h1 {
      @include heading-3;
    }

    .details-list {
      @include caption;
      gap: var(--space-1) var(--space-2);
    }
  }
</style>
