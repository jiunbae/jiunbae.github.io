---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import services from '@/data/services';
import Badge from '@/components/Badge.astro';

type IncidentSeverity = 'critical' | 'major' | 'minor' | 'maintenance';
type IncidentStatus = 'investigating' | 'identified' | 'monitoring' | 'resolved' | 'scheduled';
type BadgeTone = 'success' | 'warning' | 'error' | 'info' | 'neutral' | 'accent';

const severityTone: Record<IncidentSeverity, BadgeTone> = {
  critical: 'error',
  major: 'warning',
  minor: 'warning',
  maintenance: 'info',
};
const statusTone: Record<IncidentStatus, BadgeTone> = {
  investigating: 'warning',
  identified: 'warning',
  monitoring: 'info',
  resolved: 'success',
  scheduled: 'info',
};

const allIncidents = await getCollection('incidents', ({ data }) => data.published !== false);
const incidents = allIncidents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const activeIncidents = incidents.filter(i => i.data.status !== 'resolved');

type ServiceStatus = 'operational' | 'maintenance' | 'degraded' | 'major-outage';

function getServiceStatus(serviceName: string): ServiceStatus {
  const affecting = activeIncidents.filter(i => i.data.affectedServices.includes(serviceName));
  if (affecting.length === 0) return 'operational';
  const severities = affecting.map(i => i.data.severity);
  if (severities.includes('critical')) return 'major-outage';
  if (severities.includes('major')) return 'degraded';
  if (severities.includes('maintenance')) return 'maintenance';
  return 'degraded';
}

const serviceStatuses = services.map(s => ({
  ...s,
  opStatus: getServiceStatus(s.title),
}));

const hasIssues = serviceStatuses.some(s => s.opStatus !== 'operational');

const statusLabels: Record<ServiceStatus, string> = {
  'operational': 'Operational',
  'maintenance': 'Maintenance',
  'degraded': 'Degraded',
  'major-outage': 'Major Outage',
};

const severityLabels: Record<string, string> = {
  critical: 'Critical',
  major: 'Major',
  minor: 'Minor',
  maintenance: 'Maintenance',
};

// Group incidents by date
const groupedIncidents: { date: string; items: typeof incidents }[] = [];
const dateMap = new Map<string, typeof incidents>();

for (const incident of incidents) {
  const dateKey = incident.data.date.toISOString().split('T')[0];
  if (!dateMap.has(dateKey)) {
    dateMap.set(dateKey, []);
  }
  dateMap.get(dateKey)!.push(incident);
}

for (const [date, items] of dateMap) {
  groupedIncidents.push({ date, items });
}

function formatGroupDate(dateStr: string) {
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

function formatTime(d: Date) {
  return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
}
---

<Layout title="Status" description="Service status and incident history for jiun.dev services.">
  <div class="status-page">
    <header class="status-header">
      <div>
        <h1>Status</h1>
        <p class="subtitle">Real-time operational status for all jiun.dev services</p>
      </div>
      <a href="/status-rss.xml" class="rss-link" aria-label="Status RSS Feed">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 11a9 9 0 0 1 9 9"/>
          <path d="M4 4a16 16 0 0 1 16 16"/>
          <circle cx="5" cy="19" r="1"/>
        </svg>
      </a>
    </header>

    <div class:list={['banner', hasIssues ? 'banner-warning' : 'banner-ok']} role="status" aria-live="polite">
      <span class="banner-dot" aria-hidden="true"></span>
      <span class="banner-text">{hasIssues ? 'Some systems are experiencing issues' : 'All Systems Operational'}</span>
      <span class="banner-time">{new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
    </div>

    <section class="services-section">
      <div class="section-header">
        <h2>Services</h2>
        <span class="service-count">{services.length}</span>
      </div>
      <div class="services-grid">
        {serviceStatuses.map(s => (
          <div class:list={['service-card', `status-${s.opStatus}`]}>
            <div class="service-info">
              <span class="service-dot-wrap">
                <span class="service-dot" aria-hidden="true"></span>
              </span>
              <span class="service-name">{s.title}</span>
            </div>
            <span class="service-status">{statusLabels[s.opStatus]}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="incidents-section">
      <div class="section-header">
        <h2>Incident History</h2>
      </div>
      {groupedIncidents.length === 0 ? (
        <div class="no-incidents">
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <p>No incidents reported. All systems running smoothly.</p>
        </div>
      ) : (
        groupedIncidents.map(group => (
          <div class="incident-group">
            <div class="incident-date-row">
              <span class="incident-date">{formatGroupDate(group.date)}</span>
              <span class="incident-date-line"></span>
            </div>
            {group.items.map(incident => (
              <a href={`/status/${incident.id}/`} class="incident-card">
                <div class="incident-left">
                  <span class:list={['severity-indicator', `sev-${incident.data.severity}`]}></span>
                  <div class="incident-info">
                    <span class="incident-title">{incident.data.title}</span>
                    <span class="incident-meta">
                      <Badge tone={severityTone[incident.data.severity as IncidentSeverity]} weight="solid">
                        {severityLabels[incident.data.severity]}
                      </Badge>
                      <span class="incident-services">
                        {incident.data.affectedServices.join(', ')}
                      </span>
                    </span>
                  </div>
                </div>
                <div class="incident-right">
                  <Badge tone={statusTone[incident.data.status as IncidentStatus]}>
                    {incident.data.status}
                  </Badge>
                  <span class="incident-time">{formatTime(incident.data.date)}</span>
                </div>
              </a>
            ))}
          </div>
        ))
      )}
    </section>
  </div>
</Layout>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .status-page {
    max-width: var(--container-list);
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .status-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-8);

    h1 {
      @include display-2;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }
  }

  .subtitle {
    @include body;
    color: var(--text-muted);
    margin: var(--space-1) 0 0;
    line-height: 1.6;
  }

  .rss-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-lg);
    color: var(--text-muted);
    transition: background-color var(--duration-base) var(--easing-standard), color var(--duration-base) var(--easing-standard), border-color var(--duration-base) var(--easing-standard);
    margin-top: var(--space-1);

    &:hover {
      color: var(--primary-c1);
      background: color-mix(in srgb, var(--primary-c1) 10%, transparent);
    }
  }

  // Banner
  .banner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    font-weight: 600;
    @include body;
    margin-bottom: var(--space-10);
    border: 1px solid transparent;
  }

  .banner-ok {
    background: color-mix(in srgb, var(--state-success) 8%, transparent);
    border-color: color-mix(in srgb, var(--state-success) 20%, transparent);
    color: var(--state-success);

    .banner-dot {
      background: var(--state-success);
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--state-success) 40%, transparent);
      animation: pulse-green 2s infinite;
    }
  }

  .banner-warning {
    background: color-mix(in srgb, var(--state-warning) 8%, transparent);
    border-color: color-mix(in srgb, var(--state-warning) 20%, transparent);
    color: var(--state-warning);

    .banner-dot {
      background: var(--state-warning);
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--state-warning) 40%, transparent);
      animation: pulse-amber 2s infinite;
    }
  }

  .banner-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .banner-text {
    flex: 1;
  }

  .banner-time {
    @include caption;
    font-weight: 400;
    color: var(--text-secondary);  /* opacity-only fails contrast over banner tint */
  }

  @keyframes pulse-green {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--state-success) 40%, transparent); }
    70% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--state-success) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--state-success) 0%, transparent); }
  }

  @keyframes pulse-amber {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--state-warning) 40%, transparent); }
    70% { box-shadow: 0 0 0 8px color-mix(in srgb, var(--state-warning) 0%, transparent); }
    100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--state-warning) 0%, transparent); }
  }

  // Section headers
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);

    h2 {
      @include heading-2;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
    }
  }

  .service-count {
    @include eyebrow;
    font-weight: 500;
    padding: var(--space-px) var(--space-1);
    border-radius: var(--radius-lg);
    background: var(--border-subtle);
    color: var(--text-secondary);
  }

  // Services grid
  .services-section {
    margin-bottom: var(--space-12);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-3);
  }

  .service-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--article-background);
    border: 1px solid var(--border-subtle);
    transition: transform var(--duration-base) var(--easing-standard), box-shadow var(--duration-base) var(--easing-standard);

    &:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }
  }

  .service-info {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .service-dot-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .service-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .service-name {
    font-weight: 500;
    @include body-sm;
    color: var(--text-primary);
  }

  .service-status {
    @include caption;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .status-operational {
    .service-dot { background: var(--state-success); }
    .service-status { color: var(--state-success); }
  }
  .status-maintenance {
    .service-dot { background: var(--state-info); }
    .service-status { color: var(--state-info); }
  }
  .status-degraded {
    .service-dot { background: var(--state-warning); }
    .service-status { color: var(--state-warning); }
  }
  .status-major-outage {
    .service-dot { background: var(--state-error); }
    .service-status { color: var(--state-error); }
  }

  // Incidents
  .incidents-section {
    margin-bottom: var(--space-8);
  }

  .no-incidents {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-12) var(--space-8);
    border-radius: var(--radius-lg);
    background: var(--article-background);
    border: 1px solid var(--border-subtle);
    text-align: center;

    svg {
      color: var(--state-success);
      opacity: 0.6;
    }

    p {
      color: var(--text-muted);
      @include body-sm;
      margin: 0;
    }
  }

  .incident-group {
    margin-bottom: var(--space-6);
  }

  .incident-date-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
  }

  .incident-date {
    @include caption;
    font-weight: 600;
    color: var(--text-muted);
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .incident-date-line {
    flex: 1;
    height: 1px;
    background: var(--border-subtle);
  }

  .incident-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-lg);
    background: var(--article-background);
    border: 1px solid var(--border-subtle);
    text-decoration: none;
    margin-bottom: var(--space-2);
    transition: transform var(--duration-base) var(--easing-standard), box-shadow var(--duration-base) var(--easing-standard), border-color var(--duration-base) var(--easing-standard);

    &:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
      border-color: var(--border-default);
    }
  }

  .incident-left {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex: 1;
    min-width: 0;
  }

  .severity-indicator {
    width: 4px;
    height: 36px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .sev-critical { background: var(--state-error); }
  .sev-major { background: var(--state-warning); }
  .sev-minor { background: var(--state-warning); }
  .sev-maintenance { background: var(--state-info); }

  .incident-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .incident-title {
    font-weight: 600;
    @include body-sm;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .incident-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    @include caption;
  }

  .severity-badge {
    @include eyebrow;
    font-weight: 600;
    padding: var(--space-0_5) var(--space-2);
    border-radius: var(--radius-md);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .severity-critical {
    background: color-mix(in srgb, var(--state-error) 15%, transparent);
    color: var(--state-error);
  }

  .severity-major {
    background: color-mix(in srgb, var(--state-warning) 15%, transparent);
    color: var(--state-warning);
  }

  .severity-minor {
    background: color-mix(in srgb, var(--state-warning) 12%, transparent);
    color: var(--state-warning);
  }

  .severity-maintenance {
    background: color-mix(in srgb, var(--state-info) 15%, transparent);
    color: var(--state-info);
  }

  .incident-services {
    color: var(--text-muted);
    @include caption;
  }

  .incident-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
    flex-shrink: 0;
  }

  .status-pill {
    @include eyebrow;
    font-weight: 600;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-lg);
    text-transform: capitalize;
  }

  .pill-resolved {
    background: color-mix(in srgb, var(--state-success) 12%, transparent);
    color: var(--state-success);
  }

  .pill-investigating, .pill-identified {
    background: color-mix(in srgb, var(--state-warning) 12%, transparent);
    color: var(--state-warning);
  }

  .pill-monitoring {
    background: color-mix(in srgb, var(--state-info) 12%, transparent);
    color: var(--state-info);
  }

  .pill-scheduled {
    background: color-mix(in srgb, var(--text-muted) 12%, transparent);
    color: var(--text-muted);
  }

  .incident-time {
    @include caption;
    color: var(--text-muted);  /* was --border-default which is too pale for text */
    font-variant-numeric: tabular-nums;
  }

  @include belowTablet {
    .status-header h1 {
      @include heading-1;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .incident-card {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3);
    }

    .incident-right {
      flex-direction: row;
      align-items: center;
      gap: var(--space-2);
      width: 100%;
    }

    .incident-time {
      margin-left: auto;
    }

    .banner-time {
      display: none;
    }
  }
</style>
