---
import Layout from '@/layouts/Layout.astro';
import PhysicsSandbox from '@/views/PhysicsSandbox';
---

<Layout title="Physics Sandbox" description="Interactive 2D rigid body physics with circles, boxes, springs, gravity gun, and explosions">
  <a href="/playground/" class="back-to-playground" aria-label="Back to playground">&larr; Playground</a>
  <PhysicsSandbox client:only="react" />
</Layout>

<style>
  .back-to-playground {
    position: fixed;
    top: 80px;
    left: 1rem;
    z-index: 40;
    padding: var(--space-1) var(--space-3);
    background: var(--article-background);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: rem(13px);
    font-weight: 500;
    opacity: 0.7;
    transition: opacity var(--duration-base) var(--easing-standard);
  }
  .back-to-playground:hover {
    opacity: 1;
  }
</style>
