---
import Layout from '@/layouts/Layout.astro';
import KindBadge from '@/components/KindBadge.astro';
import type { Kind } from '@/components/KindBadge.astro';
import StatusBadge from '@/components/StatusBadge.astro';
import type { Status } from '@/components/StatusBadge.astro';
import { designMeta } from '@/components/design/_meta';

const releases = [
  {
    version: 'v0.3',
    date: '2026.05.24',
    status: 'Current',
    summary: '4명 cold reviewer (Atomic + Nielsen/RUI + WCAG/ARIA + Gestalt/IA) 3 라운드로 평균 8.80 → 9.49. Layout·spacing·motion 토큰 일관성 마무리.',
    changes: [
      // Spacing / motion / radius sweep
      { kind: 'changed', text: 'spacing 토큰 사이트 전반 200+곳 → var(--space-*) (15개 페이지, Layout 포함). 4-px grid 정렬 완성' },
      { kind: 'changed', text: 'Layout.astro 9개 transition → var(--duration-*) var(--easing-standard)' },
      { kind: 'changed', text: 'Layout/projects/status/posts/about/tools radius 라ル(8/10/12/20/0.25rem/0.5rem 등) → --radius-md/lg/2xl' },
      { kind: 'changed', text: 'projects.astro transition: all 0.2s, color 0.2s 등 → 토큰 (21개)' },
      // Token additions
      { kind: 'added', text: 'Chip에 size?: \'sm\' | \'md\' prop + .chip-sm 변형 (projects 태그 size="sm" 호출 silent drop 수정)' },
      { kind: 'added', text: 'card-interactive($lift) mixin — figure-ground elevation + :has(focus-visible) parity + prefers-reduced-motion 폴백' },
      { kind: 'added', text: '--scrim 토큰 (모달/드로어 backdrop, rgba(0,0,0,0.5) 흡수)' },
      { kind: 'added', text: '--red-600/--red-700 primitive + --state-error → red-700 (light: 4.5:1 small text AA), dark: #FCA5A5' },
      { kind: 'added', text: '_tokens.scss container scale 통합 (xs/sm/md/xl/wide + 레거시 alias)' },
      // Information architecture
      { kind: 'changed', text: 'Layout 네비 — 주요 텍스트 nav vs 유틸리티 아이콘 cluster 사이에 .nav-divider 추가 (Gestalt common region)' },
      { kind: 'changed', text: 'index .post-item 카드 hover/focus elevation (shadow-md → lg + translateY)' },
      { kind: 'changed', text: 'posts/index .post-item 행 hover background-color + focus-visible parity' },
      { kind: 'changed', text: 'notes/index filter-btn raw transition: all 0.2s → 토큰' },
      // A11y
      { kind: 'a11y', text: 'projects 카테고리 필터 — role="group" + 동적 aria-pressed (SR 토글 상태 노출, SC 4.1.2)' },
      { kind: 'a11y', text: 'CommentSection h3 Comments → h2 (heading hierarchy 정상화)' },
      { kind: 'a11y', text: 'status/[slug] breadcrumb nav aria-label="Breadcrumb"' },
      { kind: 'a11y', text: 'about .name-kr span에 lang="ko" (SC 3.1.2 Language of Parts)' },
      { kind: 'a11y', text: '--state-error 라이트 테마 red-500(3.76:1) → red-700(4.5:1+) — deleteBtn 등 small text AA 통과' },
      { kind: 'a11y', text: 'status/projects 데코 SVG 9개에 aria-hidden="true" 추가 (SC 1.1.1)' },
      { kind: 'a11y', text: '.nav-divider role/aria-orientation 제거 (aria-hidden과 모순 해소)' },
    ],
  },
  {
    version: 'v0.2',
    date: '2026.05.24',
    status: 'Deprecated',
    summary: '블로그 전체에 디자인 시스템 적용. 9 라운드 cold review(Atomic Design + Nielsen + WCAG 2.2 AA)로 평균 5.40 → 9.10.',
    changes: [
      // Token sweep across the blog
      { kind: 'changed', text: '레거시 --gray-N 250+곳을 --text-*/--surface-*/--border-* semantic 토큰으로 치환 (about, projects, contact, posts/[slug], notes/[slug], reviews/[slug], status/*, Layout, CommentSection 등)' },
      { kind: 'changed', text: 'status 페이지 56곳 hex(#22c55e/#f59e0b/#ef4444/#60a5fa/#d97706/#a78bfa) → --state-success/warning/error/info 토큰' },
      { kind: 'changed', text: 'projects.astro hex(#22c55e/#eab308/#6b7280) → --state-*/text-muted 토큰' },
      { kind: 'changed', text: 'Layout.astro hardcoded rgba shadow (3개) → --shadow-sm/md/lg 토큰' },
      { kind: 'changed', text: 'status 펄스 애니메이션 rgba → color-mix(in srgb, var(--state-*) ..., transparent) 패턴' },
      { kind: 'changed', text: 'posts/[slug] code-inline #d63384 → var(--state-error)' },
      { kind: 'changed', text: 'CommentSection 하드코딩 \'#fff\' 3곳 → var(--text-on-accent) (다크 모드 2.5:1 대비비 → AA 통과)' },
      { kind: 'changed', text: 'scroll-to-top, deleteBtn 등 → semantic token 사용' },
      // Typography mixin adoption
      { kind: 'changed', text: '14개 페이지 raw font-size (~150개) → typography 믹스인 (display-1/2, heading-1/2/3, body-lg/body/sm, caption, eyebrow) 적용' },
      { kind: 'changed', text: 'Atomic 컴포넌트 Chip/PostCard/Note의 raw rem() → 믹스인 (atom 레이어 일관성)' },
      { kind: 'added', text: '--measure: 38rem 토큰 신설 (한글 본문 45-75자 CPL 가이드)' },
      // Component primitive adoption
      { kind: 'added', text: 'status/index + status/[slug] severity/status pill → <Badge tone weight> (디자인 외부에서 첫 Badge 소비)' },
      { kind: 'added', text: '4개 리스트 페이지(index/posts/notes/reviews) 필터 + 태그 → <Chip as="button" pressed> + <Chip>' },
      { kind: 'added', text: 'about.astro skill-tag (3개소) → <Chip>' },
      { kind: 'added', text: '404 페이지 재작성 — Korean voice + Search 검색 어포던스 + 다중 복구 링크 + Button-style 토큰' },
      // Korean readability
      { kind: 'added', text: '_global.scss body에 word-break: keep-all + overflow-wrap: anywhere 전역 적용 (한글 어절 분할 방지)' },
      { kind: 'changed', text: 'posts/notes/reviews/status detail의 .article-content/.incident-body에 max-width: var(--measure) + margin-inline: auto 적용' },
      { kind: 'changed', text: '한글 본문 line-height 1.7~1.85 일관 적용' },
      // A11y — substantial
      { kind: 'a11y', text: '4개 리스트(index/posts/notes/reviews) 중첩 anchor (<a>가 <h2> wrap) → stretched-link 패턴 (heading-in-link 제거 + 카드 전체 hit area 유지)' },
      { kind: 'a11y', text: '4개 empty-filter 메시지 → role="status" aria-live="polite"' },
      { kind: 'a11y', text: 'SearchModal APG Combobox 1.2 패턴 (role=combobox, aria-controls, aria-expanded, aria-activedescendant, aria-autocomplete, listbox id, option ids, focus-trap에서 option 제외, status를 listbox 밖으로 분리, Close 버튼 추가)' },
      { kind: 'a11y', text: 'Drawer: role="dialog" + aria-modal="true" + aria-controls=drawer + 배경 main inert 토글 + 햄버거 aria-label 동적 (Menu ↔ Close menu)' },
      { kind: 'a11y', text: 'Projects tabs: APG Tabs 키보드 패턴 (roving tabindex + ArrowLeft/Right/Home/End + aria-labelledby + tabindex=0 on panels)' },
      { kind: 'a11y', text: 'CommentSection: 모든 input/textarea에 aria-label, Reply/Edit/Delete 버튼 disambiguating aria-label, Cancel/Save type="button", 인라인 버튼 min-height 24×24px (WCAG 2.5.8), deleteBtn에 underline+bold (color 단독 의존 제거)' },
      { kind: 'a11y', text: 'Layout 모바일 로고 aria-label="Home" (heading display:none 시 accessible name 보존)' },
      { kind: 'a11y', text: 'about.astro h4 → h3 (WCAG 2.4.6 sequential heading hierarchy)' },
      { kind: 'a11y', text: 'contact 이모지 아이콘 (3종) aria-hidden="true"' },
      { kind: 'a11y', text: 'status 페이지 데코 dots (banner/service/tag) aria-hidden="true"' },
      { kind: 'a11y', text: 'status banner role="status" + aria-live="polite" (동적 상태 알림)' },
      { kind: 'a11y', text: 'reviews/[slug] 평점 패턴: aria-hidden visual + sr-only text (aria-label on <p> 안티패턴 제거)' },
      { kind: 'a11y', text: '리스트 페이지 카드 썸네일 alt="" (제목 링크 옆에 있어 데코로 처리, SR 중복 announce 제거)' },
      // Voice
      { kind: 'changed', text: 'Voice 8번 원칙 추가 — UI 라벨은 짧고 영문 우선, 본문은 한글 (Voice 페이지 자체가 그 예시)' },
    ],
  },
  {
    version: 'v0.1',
    date: '2026.05.22',
    status: 'Deprecated',
    summary: '디자인 시스템 첫 버전. 토큰 레이어와 핵심 컴포넌트를 정리.',
    changes: [
      { kind: 'added', text: 'Primitive + Semantic 2-레이어 토큰 체계 (text, surface, border, accent)' },
      { kind: 'added', text: 'Foundation 토큰 — space(11), radius(6), shadow(5), motion(4d+4e), z-index(7)' },
      { kind: 'added', text: 'Typography 9단계 스케일 (display/heading/body/caption/label/code)' },
      { kind: 'added', text: 'Pretendard + Fira Code 폰트 패밀리 토큰화' },
      { kind: 'added', text: 'Chip / Button / PostCard / Note 4개 공유 컴포넌트' },
      { kind: 'added', text: 'State 컬러 (success/warning/error/info) + bg 변형' },
      { kind: 'added', text: '/design 매거진 표지 스타일 spec doc' },
      { kind: 'changed', text: 'Primary 색을 #64B5F6 → #2563EB로 변경 (대비비 2.4:1 → 5.2:1, WCAG AA pass)' },
      { kind: 'changed', text: 'Body weight 400 → 500 (한글 가독성 강화)' },
      { kind: 'changed', text: '의미 토큰을 color-mix()로 텍스트 색에서 파생하는 패턴 도입' },
      { kind: 'a11y', text: 'WCAG AA 대비비 검증, focus-visible ring 토큰화' },
      { kind: 'a11y', text: 'prefers-reduced-motion 전역 처리' },
    ],
  },
];

/* Kind 라벨은 KindBadge 컴포넌트로 이전됨 — Kind 타입은 KindBadge에서 import */
---

<Layout
  title="Changelog — Design System"
  description="디자인 시스템 버전별 변경 기록."
>
  <div class="cl">
    <header class="cl-head">
      <p class="cl-back"><a href="/design">← Design System</a></p>
      <p class="cl-eyebrow">Changelog</p>
      <h1 class="cl-title">변경 기록</h1>
      <p class="cl-lede">
        {designMeta.version}, 토큰 {designMeta.tokenCount}개, 컴포넌트 {designMeta.componentCount}개. 시스템이 페이지 위에서 살아갑니다.
      </p>
    </header>

    {releases.map(release => (
      <section class="cl-release">
        <header class="cl-release-head">
          <div class="cl-version">
            <h2>{release.version}</h2>
            <StatusBadge status={release.status as Status} />
          </div>
          <time class="cl-date" datetime={release.date.replace(/\./g, '-')}>{release.date}</time>
        </header>

        <p class="cl-summary">{release.summary}</p>

        <ul class="cl-changes">
          {release.changes.map(c => (
            <li class="cl-change">
              <KindBadge kind={c.kind as Kind} />
              <span class="cl-text">{c.text}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <footer class="cl-foot">
      <p>변경 제안은 <a href="https://github.com/jiunbae/jiunbae.github.io" class="cl-link">GitHub</a>에서 받습니다.</p>
    </footer>
  </div>
</Layout>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .cl {
    max-width: var(--container-doc);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6) var(--space-20);
    color: var(--text-primary);
  }

  .cl-head {
    margin: 0 0 var(--space-16);
  }

  .cl-back {
    margin: 0 0 var(--space-8);

    a {
      font-family: var(--font-mono);
      font-size: rem(12px);
      font-weight: 600;
      color: var(--text-muted);
      text-decoration: none;
      letter-spacing: 0.04em;
      transition: color var(--duration-base) var(--easing-standard);

      &:hover { color: var(--accent-default); }
    }
  }

  .cl-eyebrow {
    font-family: var(--font-mono);
    font-size: rem(12px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-default);
    margin: 0 0 var(--space-3);
  }

  .cl-title {
    @include display-2;
    margin: 0 0 var(--space-4);
  }

  .cl-lede {
    @include body-lg;
    color: var(--text-secondary);
    margin: 0;
    max-width: 560px;
  }

  .cl-release {
    padding: var(--space-8) 0;
    border-top: 1px solid var(--border-default);
  }

  .cl-release-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 0 0 var(--space-4);
  }

  .cl-version {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-3);

    h2 {
      font-family: var(--font-mono);
      font-size: rem(24px);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0;
      color: var(--text-primary);
    }
  }

  /* .cl-status는 <StatusBadge>로 이전됨 */

  .cl-date {
    font-family: var(--font-mono);
    font-size: rem(12px);
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .cl-summary {
    @include body;
    color: var(--text-secondary);
    margin: 0 0 var(--space-6);
  }

  .cl-changes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .cl-change {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-2) 0;
    border-top: 1px dashed var(--border-subtle);

    @include belowMobile {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }

  /* .cl-kind / .cl-change-* 색상 분기는 <KindBadge>로 이전됨 */

  /* Badge primitive 실제 클래스는 .badge — KindBadge wrapper도 같은 클래스 사용 */
  .cl-change > :global(.badge) {
    justify-self: start;
    align-self: center;
  }

  .cl-text {
    @include body-sm;
    color: var(--text-primary);
  }

  .cl-foot {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-default);

    p {
      @include caption;
      color: var(--text-muted);
      margin: 0;
    }
  }

  .cl-link {
    color: var(--text-link);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--text-link) 30%, transparent);
    text-underline-offset: 2px;

    &:hover { text-decoration-color: var(--text-link); }

    &:focus-visible {
      outline: 2px solid var(--border-focus);
      outline-offset: 2px;
      border-radius: var(--radius-sm);
    }
  }

  /* forced-colors fallback */
  @media (forced-colors: active) {
    .cl-back a:focus-visible,
    .cl-link:focus-visible {
      outline: 2px solid CanvasText;
      outline-offset: 2px;
    }
  }
</style>
