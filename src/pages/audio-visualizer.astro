---
import Layout from '@/layouts/Layout.astro';
import AudioVisualizer from '@/views/AudioVisualizer';
---

<Layout title="Audio Visualizer" description="Real-time 3D audio visualization with terrain, radial, and waveform modes - supports file input and microphone">
  <a href="/playground/" class="back-to-playground" aria-label="Back to playground">&larr; Playground</a>
  <AudioVisualizer client:only="react" />
</Layout>

<style>
  .back-to-playground {
    position: fixed;
    top: 80px;
    left: 1rem;
    z-index: 40;
    padding: var(--space-1) var(--space-3);
    background: var(--article-background);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: rem(13px);
    font-weight: 500;
    opacity: 0.7;
    transition: opacity var(--duration-base) var(--easing-standard);
  }
  .back-to-playground:hover {
    opacity: 1;
  }
</style>
