---
import Layout from '@/layouts/Layout.astro';
import Sidenav from '@/components/design/Sidenav.astro';
import Cover from '@/components/design/Cover.astro';
import SectionColor from '@/components/design/SectionColor.astro';
import SectionTypography from '@/components/design/SectionTypography.astro';
import SectionFoundation from '@/components/design/SectionFoundation.astro';
import SectionInUse from '@/components/design/SectionInUse.astro';
import SectionA11y from '@/components/design/SectionA11y.astro';
import SectionContent from '@/components/design/SectionContent.astro';
import Colophon from '@/components/design/Colophon.astro';
---

<Layout
  title="Design вҖ” Jiun's Blog"
  description="лё”лЎңк·ё м „л°ҳм—җм„ң мӮ¬мҡ©н•ҳлҠ” нҶ нҒ°кіј м»ҙнҸ¬л„ҢнҠёмқҳ лӘ…м„ё."
>
  <div class="cv">
    <Sidenav />
    <Cover />

    <!-- ====== 01 Color ====== -->
    <SectionColor />

    <!-- ====== 02 Typography ====== -->
    <SectionTypography />

    <!-- ====== 03 Foundation ====== -->
    <SectionFoundation />

    <!-- ====== 04 In Use ====== -->
    <SectionInUse />

    <!-- ====== 05 Accessibility ====== -->
    <SectionA11y />

    <!-- ====== 06 Content ====== -->
    <SectionContent />

    <Colophon />
  </div>
</Layout>

<script>
  // нҺҳмқҙм§Җ мҠӨнҒ¬лҰҪнҠёлҘј init()мңјлЎң л¬¶м–ҙ view-transitions(astro:page-load) мӢңм—җлҸ„ мһ¬л°”мқёл”© к°ҖлҠҘ.
  // AbortControllerлЎң мқҙм „ лқјмҡҙл“ңмқҳ listenerмҷҖ IntersectionObserverлҘј лӘЁл‘җ н•ҙм ңн•ҳм—¬
  // нҺҳмқҙм§Җ м „нҷҳ мӢң leakмқҙ лҲ„м Ғлҗҳм§Җ м•ҠлҸ„лЎқ н•Ё.
  const LIVE_REGION_ID = 'design-copy-live-region';
  let currentController: AbortController | null = null;

  // announce()лҠ” л§Ө нҳём¶ң мӢң regionмқ„ idлЎң мһ¬мЎ°нҡҢ вҖ” мҳӣ DOMмқҳ region нҒҙлЎңм Җ лҲ„м„Ө л°©м§Җ.
  const announce = (msg: string) => {
    const region = document.getElementById(LIVE_REGION_ID);
    if (!region) return;
    region.textContent = '';
    requestAnimationFrame(() => { region.textContent = msg; });
  };

  function init() {
  // мқҙм „ init()мқҳ listener/observerлҘј лӘЁл‘җ н•ҙм ң
  currentController?.abort();
  currentController = new AbortController();
  const signal = currentController.signal;

  // кіөмҡ© sr-only live region вҖ” id кё°л°ҳ idempotent
  let tokenLiveRegion = document.getElementById(LIVE_REGION_ID) as HTMLSpanElement | null;
  if (!tokenLiveRegion) {
    tokenLiveRegion = document.createElement('span');
    tokenLiveRegion.id = LIVE_REGION_ID;
    tokenLiveRegion.className = 'sr-only';
    tokenLiveRegion.setAttribute('aria-live', 'polite');
    tokenLiveRegion.setAttribute('aria-atomic', 'true');
    document.body.appendChild(tokenLiveRegion);
  }

  document.querySelectorAll<HTMLButtonElement>('.cv-token[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add('cv-token-copied');
        announce(`${text} copied to clipboard`);
        setTimeout(() => btn.classList.remove('cv-token-copied'), 1200);
      } catch {
        btn.classList.add('cv-token-failed');
        announce('Copy failed');
        setTimeout(() => btn.classList.remove('cv-token-failed'), 1200);
      }
    }, { signal });
  });

  // Sidenav scrollspy вҖ” IntersectionObserverлЎң нҳ„мһ¬ м„№м…ҳм—җ aria-current л¶Җм—¬
  const sidenavLinks = document.querySelectorAll<HTMLAnchorElement>('.cv-sidenav a[data-section]');
  const sections = Array.from(sidenavLinks).map(a => {
    const id = a.dataset.section;
    return id ? document.getElementById(id) : null;
  }).filter((el): el is HTMLElement => !!el);

  if (sections.length > 0) {
    const setActive = (id: string) => {
      sidenavLinks.forEach(a => {
        if (a.dataset.section === id) {
          a.setAttribute('aria-current', 'location');
        } else {
          a.removeAttribute('aria-current');
        }
      });
    };

    const observer = new IntersectionObserver((entries) => {
      // нҷ”л©ҙ мғҒлӢЁм—җ к°ҖмһҘ к°Җк№Ңмҡҙ м„№м…ҳ м„ нғқ
      const visible = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible[0]) setActive(visible[0].target.id);
    }, {
      rootMargin: '-80px 0px -60% 0px',
      threshold: 0,
    });

    sections.forEach(s => observer.observe(s));
    // signal abort мӢң observer н•ҙм ң вҖ” view-transition leak л°©м§Җ
    signal.addEventListener('abort', () => observer.disconnect(), { once: true });

    // Seed: location.hash лҳҗлҠ” viewport topкіј к°ҖмһҘ к°Җк№Ңмҡҙ м„№м…ҳмңјлЎң мҙҲкё° нҷңм„ұнҷ” н‘ңмӢң.
    // мӮ¬мҡ©мһҗк°Җ мҠӨнҒ¬лЎӨ м „мқҙлқјлҸ„ sidenavк°Җ м–ҙл–Ө м„№м…ҳмқ„ ліҙкі  мһҲлҠ”м§Җ м•Ңл ӨмӨҢ.
    const hashId = location.hash.replace('#', '');
    if (hashId && sections.some(s => s.id === hashId)) {
      setActive(hashId);
    } else {
      const seedTarget = sections.reduce((best, s) => {
        const top = s.getBoundingClientRect().top;
        return top <= 80 && top > best.top ? { id: s.id, top } : best;
      }, { id: sections[0]!.id, top: -Infinity });
      setActive(seedTarget.id);
    }
  }

  // лӘЁл“  cv-code лё”лЎқм—җ copy лІ„нҠј лҸҷм Ғ м¶”к°Җ
  // Astro scoped CSSлҘј м Ғмҡ©н•ҳл Өл©ҙ preмқҳ data-astro-cid-* мҶҚм„ұмқ„ мғҲ мҡ”мҶҢм—җлҸ„ ліөм ң
  // HMR/view-transitionsм—җм„ң л‘җ лІҲ мӢӨн–үлҸјлҸ„ buttonsк°Җ лҲ„м Ғлҗҳм§Җ м•ҠлҸ„лЎқ л¶ҖлӘЁ мІҙнҒ¬.
  document.querySelectorAll('pre.cv-code').forEach((pre) => {
    if (pre.parentElement?.classList.contains('cv-code-wrap')) return;

    const cidAttr = pre.getAttributeNames().find(n => n.startsWith('data-astro-cid-'));

    const wrap = document.createElement('div');
    wrap.className = 'cv-code-wrap';
    if (cidAttr) wrap.setAttribute(cidAttr, '');
    pre.parentNode?.insertBefore(wrap, pre);
    wrap.appendChild(pre);

    const btn = document.createElement('button');
    btn.className = 'cv-code-copy';
    btn.type = 'button';
    btn.textContent = 'Copy';
    // accessible name parity (WCAG 2.5.3): visible textк°Җ aria-labelм—җ нҸ¬н•Ё
    btn.setAttribute('aria-label', 'Copy code');
    if (cidAttr) btn.setAttribute(cidAttr, '');

    // лқјмқҙлёҢ лҰ¬м „мқҖ нҺҳмқҙм§Җ лӢЁмң„ кіөмҡ© announce()лҘј мӮ¬мҡ© вҖ” лІ„нҠј м•Ҳм—җ л‘җл©ҙ accessible nameм—җ м„һмһ„
    btn.addEventListener('click', async () => {
      const text = pre.querySelector('code')?.textContent ?? '';
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied';
        btn.classList.add('copied');
        announce('Code copied to clipboard');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 1500);
      } catch {
        btn.textContent = 'Failed';
        announce('Copy failed');
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      }
    }, { signal });
    wrap.appendChild(btn);
  });
  } // init()

  init();
  // astro:page-loadлҠ” ViewTransitions мӮ¬мҡ© мӢң нҺҳмқҙм§Җ м „нҷҳл§ҲлӢӨ л°ңнҷ”. нҳ„мһ¬ лҜёмӮ¬мҡ©мқҙлқјлҸ„ л°©м–ҙм ҒмңјлЎң.
  document.addEventListener('astro:page-load', init);
</script>

<style lang="scss" is:global>
  @use '../styles/pages/design';
</style>
