---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { fmtDate } from '@/utils/date';
import Chip from '@/components/Chip.astro';

const allNotes = await getCollection('notes', ({ data }) => data.published !== false);
const sortedNotes = allNotes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique tags with counts
const tagCounts = sortedNotes.reduce((acc, note) => {
  note.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const totalCount = sortedNotes.length;

// Render all notes content
const notesWithContent = await Promise.all(
  sortedNotes.map(async (note) => {
    const { Content } = await render(note);
    return { note, Content };
  })
);
---

<Layout
  title="Notes | Jiunbae"
  description="짧은 생각과 메모들"
>
  <div class="main">
    <h1 class="sr-only">Notes</h1>
    <div class="tag-list" role="group" aria-label="Filter by tag">
      <Chip as="button" type="button" class="tag-button active" pressed={true} data-tag="all">All ({totalCount})</Chip>
      {tags.map(([tag, count]) => (
        <Chip as="button" type="button" class="tag-button" pressed={false} data-tag={tag}>{tag} ({count})</Chip>
      ))}
    </div>

    <div class="note-list" id="note-list">
      {notesWithContent.map(({ note, Content }) => (
        <article
          class="note-item"
          data-tags={JSON.stringify(note.data.tags)}
          data-note-slug={note.data.permalink?.replace(/^\//, '')}
        >
          <header class="note-header">
            <h2 class="note-title">{note.data.title}</h2>
            <time class="note-date" datetime={note.data.date.toISOString()}>
              {fmtDate(note.data.date)}
            </time>
          </header>
          <div class="note-content prose">
            <Content />
          </div>
          <footer class="note-footer">
            {note.data.tags.length > 0 && (
              <div class="note-tags">
                {note.data.tags.map(tag => (
                  <Chip>{tag}</Chip>
                ))}
              </div>
            )}
            <button class="share-button" data-url={`/notes${note.data.permalink}`} aria-label="Share">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
            </button>
          </footer>
        </article>
      ))}
    </div>
    <p class="empty-filter-message" id="empty-filter-msg" role="status" aria-live="polite" style="display:none">선택한 태그에 해당하는 노트가 없습니다.</p>
  </div>
</Layout>

<script>
  // Tag filtering
  const tagButtons = document.querySelectorAll('.tag-button');
  const noteList = document.getElementById('note-list');
  const noteItems = noteList?.querySelectorAll('.note-item');

  // Pre-parse tags data for filtering
  const tagData = new Map();
  noteItems?.forEach(item => {
    tagData.set(item, JSON.parse((item as HTMLElement).dataset.tags || '[]'));
  });

  tagButtons.forEach(button => {
    button.addEventListener('click', () => {
      const selectedTag = (button as HTMLElement).dataset.tag;

      tagButtons.forEach(btn => {
        btn.classList.remove('active');
        btn.classList.remove('chip-active');
        btn.classList.add('chip-default');
        btn.setAttribute('aria-pressed', 'false');
      });
      button.classList.add('active');
      button.classList.remove('chip-default');
      button.classList.add('chip-active');
      button.setAttribute('aria-pressed', 'true');

      let visibleCount = 0;
      noteItems?.forEach((item) => {
        const noteTags = tagData.get(item);
        if (selectedTag === 'all' || noteTags.includes(selectedTag)) {
          (item as HTMLElement).style.display = '';
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });

      const emptyMsg = document.getElementById('empty-filter-msg');
      if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
    });
  });

  // Share functionality
  document.querySelectorAll('.share-button').forEach(button => {
    button.addEventListener('click', async () => {
      const url = window.location.origin + (button as HTMLElement).dataset.url;
      try {
        if (navigator.share) {
          await navigator.share({ url });
        } else {
          await navigator.clipboard.writeText(url);
          alert('Link copied to clipboard!');
        }
      } catch {
        // User cancelled share or clipboard API unavailable
      }
    });
  });

  // Handle URL hash for direct note linking
  const hash = window.location.hash.slice(1);
  if (hash) {
    const target = Array.from(
      document.querySelectorAll('[data-note-slug]')
    ).find(el => (el as HTMLElement).dataset.noteSlug === hash);
    if (target) {
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      target.setAttribute('data-highlighted', 'true');
      setTimeout(() => target.removeAttribute('data-highlighted'), 2500);
    }
  }
</script>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  .main {
    max-width: var(--container-doc);
    margin: 0 auto;
    padding: var(--space-6);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  /* .tag-button 로컬 스타일 제거 — <Chip as="button" pressed>로 통일 */

  .note-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .note-item {
    background: var(--surface-raised);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: box-shadow var(--duration-slow) var(--easing-standard);

    &[data-highlighted="true"] {
      box-shadow: 0 0 0 2px var(--accent-default);
    }
  }

  .note-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-4);
  }

  .note-title {
    @include heading-3;
    color: var(--text-primary);
    margin: 0;
  }

  .note-date {
    @include caption;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .note-content {
    @include body-sm;
    color: var(--text-secondary);
    line-height: 1.8;

    :global(p) {
      margin: var(--space-3) 0;
    }

    :global(a) {
      color: var(--text-link);
    }

    :global(strong) {
      font-weight: 600;
    }

    :global(ol), :global(ul) {
      padding-left: var(--space-6);
      margin: var(--space-3) 0;
    }

    :global(li) {
      margin: var(--space-1) 0;
    }

    :global(blockquote) {
      border-left: 3px solid var(--accent-default);
      padding-left: var(--space-4);
      margin: var(--space-4) 0;
      color: var(--text-muted);
    }
  }

  .note-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-default);
  }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  /* .tag 로컬 스타일 제거 — <Chip>으로 통일 */

  .share-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 1px solid var(--border-default);
    border-radius: 50%;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;

    &:hover {
      border-color: var(--primary-c1);
      color: var(--primary-c1);
    }
  }

  .empty-filter-message {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 1rem;
    @include body-sm;
  }

  @media (max-width: 640px) {
    .note-header {
      flex-direction: column;
      gap: 0.25rem;
    }

    .note-title {
      @include heading-3;
    }
  }
</style>
