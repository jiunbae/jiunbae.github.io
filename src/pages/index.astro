---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Chip from '@/components/Chip.astro';
import CommentCountLoader from '@/components/CommentCountLoader.astro';
import { fmtDate } from '@/utils/date';

const allPosts = await getCollection('posts', ({ data }) => data.published !== false);
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Get unique tags with counts
const tagCounts = sortedPosts.reduce((acc, post) => {
  post.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
const totalCount = sortedPosts.length;
---

<Layout
  title="Jiun's Blog"
  description="AI/ML 연구원의 기술 블로그"
>
  <div class="main">
    <section class="wrapper">
      <h1 class="sr-only">Posts</h1>
      <div class="tag-list" id="tag-list" role="group" aria-label="Filter by tag">
        <div class="tag-buttons" id="tag-buttons">
          <Chip as="button" variant="active" data-tag="all" aria-pressed="true">
            all ({totalCount})
          </Chip>
          {tags.map(([tag, count]) => (
            <Chip as="button" data-tag={tag} aria-pressed="false">
              {tag} ({count})
            </Chip>
          ))}
        </div>
      </div>

      <ul class="post-list" id="post-list">
        {sortedPosts.map((post) => (
          <li class="post-item" data-tags={JSON.stringify(post.data.tags)}>
            <a href={`/posts${post.data.permalink || `/${post.slug}`}`} class="post-link">
              <article class="post">
                <figure class="post-figure">
                  <div class="post-thumbnail">
                    {post.data.heroImage && !post.data.heroImage.startsWith('./') ? (
                      <img src={post.data.heroImage} alt={post.data.heroImageAlt || post.data.title} loading="lazy" />
                    ) : (
                      <img src={`/thumbs/posts${post.data.permalink || `/${post.slug}`}.png`} alt={post.data.title} loading="lazy" />
                    )}
                  </div>
                  <figcaption class="post-content">
                    <h2 class="post-title">{post.data.title}</h2>
                    {post.data.description && (
                      <p class="post-description">{post.data.description}</p>
                    )}
                    <div class="post-meta" data-comment-slug={(post.data.permalink || `/${post.slug}`).replace(/^\//, '')} data-comment-type="posts">
                      <time class="post-date" datetime={post.data.date.toISOString()}>
                        {fmtDate(post.data.date)}
                      </time>
                    </div>
                    {post.data.tags.length > 0 && (
                      <div class="post-tags">
                        {post.data.tags.map(tag => (
                          <Chip class="tag">{tag}</Chip>
                        ))}
                      </div>
                    )}
                  </figcaption>
                </figure>
              </article>
            </a>
          </li>
        ))}
      </ul>
      <p class="empty-filter-message" id="empty-filter-msg" style="display:none">선택한 태그에 해당하는 포스트가 없습니다.</p>
    </section>
  </div>
  <CommentCountLoader />
</Layout>

<script>
  const tagList = document.getElementById('tag-list');
  const postList = document.getElementById('post-list');
  const tagButtons = document.getElementById('tag-buttons');

  // Pre-parse tags data for filtering
  const postItems = postList?.querySelectorAll('.post-item');
  const tagData = new Map();
  postItems?.forEach(item => {
    tagData.set(item, JSON.parse((item as HTMLElement).dataset.tags || '[]'));
  });

  // Tag filtering
  tagList?.addEventListener('click', (e) => {
    const button = (e.target as HTMLElement).closest('.chip');
    if (!button || button.classList.contains('tag-expand')) return;

    const selectedTag = (button as HTMLElement).dataset.tag;
    if (!selectedTag) return;

    // Update active state and aria-pressed
    tagList.querySelectorAll('.chip').forEach(btn => {
      btn.classList.remove('chip-active');
      btn.classList.add('chip-default');
      btn.setAttribute('aria-pressed', 'false');
    });
    button.classList.remove('chip-default');
    button.classList.add('chip-active');
    button.setAttribute('aria-pressed', 'true');

    // Filter posts
    let visibleCount = 0;
    postItems?.forEach((item) => {
      const postTags = tagData.get(item);
      if (selectedTag === 'all' || postTags.includes(selectedTag)) {
        (item as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (item as HTMLElement).style.display = 'none';
      }
    });

    // Show empty state if no posts match
    const emptyMsg = document.getElementById('empty-filter-msg');
    if (emptyMsg) emptyMsg.style.display = visibleCount === 0 ? '' : 'none';
  });

  // Tag overflow: only collapse when tags don't fit on one line
  function adjustTagOverflow() {
    document.querySelectorAll<HTMLElement>('.post-tags').forEach(container => {
      // Reset previous state
      container.querySelector('.tag-more')?.remove();
      const tags = Array.from(container.querySelectorAll<HTMLElement>('.tag'));
      tags.forEach(t => { t.style.display = ''; });

      // Single layout pass — no overflow, nothing to do
      if (container.scrollWidth <= container.clientWidth) return;

      const containerWidth = container.clientWidth;
      const gap = parseFloat(getComputedStyle(container).columnGap || '6') || 6;
      const badgeReserve = 44; // approximate "+N" badge width incl. gap

      let used = 0;
      let visible = 0;
      for (let i = 0; i < tags.length; i++) {
        const w = tags[i].offsetWidth;
        const projected = used + w + (i > 0 ? gap : 0) + gap + badgeReserve;
        if (projected > containerWidth) break;
        used += w + (i > 0 ? gap : 0);
        visible++;
      }

      // Ensure at least one tag is visible
      if (visible === 0) visible = 1;

      for (let i = visible; i < tags.length; i++) {
        tags[i].style.display = 'none';
      }

      const hidden = tags.length - visible;
      if (hidden > 0 && tags[0]) {
        const badge = tags[0].cloneNode(false) as HTMLElement;
        badge.classList.remove('chip-default');
        badge.classList.add('chip-muted', 'tag-more');
        badge.textContent = `+${hidden}`;
        badge.style.display = '';
        container.appendChild(badge);
      }
    });
  }

  // Top tag filter overflow: collapse to "+N more" only when row overflows
  function adjustTopTagOverflow() {
    if (!tagButtons) return;
    if (tagButtons.classList.contains('expanded')) return;

    tagButtons.querySelector('.tag-expand')?.remove();
    const buttons = Array.from(tagButtons.querySelectorAll<HTMLElement>('.chip'));
    buttons.forEach(b => { b.style.display = ''; });

    if (tagButtons.scrollWidth <= tagButtons.clientWidth) return;

    const containerWidth = tagButtons.clientWidth;
    const gap = parseFloat(getComputedStyle(tagButtons).columnGap || '6') || 6;
    const expandReserve = 52;

    let used = 0;
    let visible = 0;
    for (let i = 0; i < buttons.length; i++) {
      const w = buttons[i].offsetWidth;
      const projected = used + w + (i > 0 ? gap : 0) + gap + expandReserve;
      if (projected > containerWidth) break;
      used += w + (i > 0 ? gap : 0);
      visible++;
    }

    if (visible === 0) visible = 1;
    for (let i = visible; i < buttons.length; i++) {
      buttons[i].style.display = 'none';
    }

    const hidden = buttons.length - visible;
    if (hidden > 0) {
      const expand = buttons[0].cloneNode(false) as HTMLButtonElement;
      expand.className = 'chip chip-muted tag-expand';
      expand.type = 'button';
      expand.textContent = `+${hidden}`;
      expand.removeAttribute('data-tag');
      expand.removeAttribute('aria-pressed');
      expand.style.display = '';
      expand.addEventListener('click', (e) => {
        e.stopPropagation();
        tagButtons.classList.add('expanded');
        buttons.forEach(b => { b.style.display = ''; });
        expand.remove();
      });
      tagButtons.appendChild(expand);
    }
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  const runOverflowAdjust = () => {
    adjustTopTagOverflow();
    adjustTagOverflow();
  };
  window.addEventListener('load', runOverflowAdjust);
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(runOverflowAdjust, 120);
  });
</script>

<style lang="scss">
  @use '../styles/abstracts' as *;

  .main {
    display: flex;
    flex-direction: column;
    margin: 0 auto;
    padding: var(--space-6) var(--space-5) 0;
    max-width: 1400px;

    @include desktopAndUp {
      flex-direction: row;
      padding: var(--space-6) var(--space-12) 0;
    }
  }

  .wrapper {
    flex: 1;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;

    @include tabletAndUp {
      padding: 0 var(--space-10);
    }

    @include desktopAndUp {
      padding: 0;
    }
  }

  .tag-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }

  .tag-buttons {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: var(--space-2);
    min-width: 0;

    &.expanded {
      flex-wrap: wrap;
      overflow: visible;
    }
  }

  /* .tag-button / .tag 스타일은 Chip 컴포넌트(글로벌)로 이전됨 */

  .hidden-tags {
    display: contents;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: var(--space-8) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .post-item {
    list-style: none;
  }

  .post-link {
    text-decoration: none;
    display: block;

    &:hover,
    &:focus {
      .post-title,
      .post-description,
      .post-date {
        text-decoration-color: var(--border-default);
      }
    }
  }

  .post {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: rem(144px);
    min-width: rem(300px);
    padding: var(--space-4);
    background-color: var(--surface-raised);
    box-shadow: var(--shadow-md);
    border-radius: var(--radius-lg);
  }

  .post-figure {
    flex: 1;
    display: flex;
    justify-content: space-between;
    width: 100%;
    margin: 0;
  }

  .post-content {
    flex: 1;
    width: 100%;
    flex-shrink: 1;
    min-width: 0;
    order: -1;
    display: flex;
    flex-direction: column;

    @include tabletAndUp {
      max-width: calc(100% - rem(216px));
    }
  }

  .post-title {
    @include heading-3;
    margin: 0 0 0 var(--space-1);
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--duration-base) var(--easing-standard);
  }

  .post-description {
    @include body-sm;
    margin: var(--space-1) 0 0 var(--space-1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--duration-base) var(--easing-standard);
  }

  .post-meta {
    display: flex;
    align-items: center;
    margin-left: var(--space-1);
  }

  .post-date {
    @include caption;
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--duration-base) var(--easing-standard);
  }

  .post-tags {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: var(--space-2);
    margin-top: auto;
    padding-top: var(--space-2);
    min-width: 0;
  }

  .empty-filter-message {
    @include body;
    text-align: center;
    color: var(--text-muted);
    padding: var(--space-12) var(--space-4);
  }

  .post-thumbnail {
    display: none;
    align-self: flex-start;
    width: rem(200px);
    aspect-ratio: 16 / 9;
    min-width: rem(200px);
    overflow: hidden;

    @include tabletAndUp {
      display: block;
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: var(--radius-lg);
    }
  }
</style>
